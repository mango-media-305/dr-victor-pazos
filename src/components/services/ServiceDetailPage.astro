---
// src/components/pages/services/ServiceDetailPage.astro

import MainLayout from "../../layouts/MainLayout.astro";
import { contactInfo } from "../../data/site/contact";
import {
    getCardiologyServiceHref,
    getRelatedCardiologyServices,
    type CardiologyService,
} from "../../data/services/cardiologyServices";
import {
    getGlobalSchema,
    getWebPageSchema,
} from "../../data/seo/schema";
import type { LanguageCode } from "../../data/site/siteConfig";

interface Props {
    service: CardiologyService;
    language: LanguageCode;
}

const { service, language } = Astro.props as Props;

const currentLanguage = language;
const Icon = service.icon;

const serviceImages = service.detailImages.slice(0, 3);
const slideDuration = 15;

const relatedServices = getRelatedCardiologyServices(service.id, 3);

const content = {
    en: {
        servicesLabel: "Services",
        overviewLabel: "Service overview",
        reasonsKicker: "Reasons to seek care",
        reasonsTitle: "Common reasons patients request this cardiology service.",
        expectKicker: "What to expect",
        expectTitle: "A clear visit process focused on your heart health.",
        faqKicker: "Service FAQ",
        faqTitle: "Questions patients often ask about this service.",
        relatedKicker: "Related services",
        relatedTitle: "Other cardiology services that may be helpful.",
        exploreService: "Explore service",
        callLabel: contactInfo.appointment.primaryCta.en,
        directionsLabel: contactInfo.map.directionsLabel.en,
        appointmentKicker: "Request an appointment",
        appointmentTitle: "Have questions about this service?",
        appointmentDescription:
            "Call the office to request an appointment or ask whether this type of cardiology evaluation may be appropriate for your concern.",
        emergencyNote:
            "If you are experiencing severe chest pain, sudden shortness of breath, fainting, stroke symptoms, or a medical emergency, call 911 immediately.",
        officeLabel: "Hialeah cardiology office",
        officeDescription:
            "Serving patients from Hialeah, Miami, Miami Lakes, Doral, Hialeah Gardens, Miami Gardens, and nearby Miami-Dade communities.",
        backToServices: "Back to all services",
        backHref: "/services/",
        floatingAlt: `${service.title.en} with Victor Pazos, MD in Hialeah, FL`,
    },
    es: {
        servicesLabel: "Servicios",
        overviewLabel: "Resumen del servicio",
        reasonsKicker: "Razones para buscar atención",
        reasonsTitle: "Razones comunes por las que los pacientes solicitan este servicio cardiológico.",
        expectKicker: "Qué esperar",
        expectTitle: "Un proceso claro enfocado en la salud de su corazón.",
        faqKicker: "Preguntas frecuentes",
        faqTitle: "Preguntas que los pacientes suelen hacer sobre este servicio.",
        relatedKicker: "Servicios relacionados",
        relatedTitle: "Otros servicios de cardiología que pueden ser útiles.",
        exploreService: "Explorar servicio",
        callLabel: contactInfo.appointment.primaryCta.es,
        directionsLabel: contactInfo.map.directionsLabel.es,
        appointmentKicker: "Solicitar una cita",
        appointmentTitle: "¿Tiene preguntas sobre este servicio?",
        appointmentDescription:
            "Llame a la oficina para solicitar una cita o preguntar si este tipo de evaluación cardiológica puede ser apropiada para su preocupación.",
        emergencyNote:
            "Si está experimentando dolor fuerte en el pecho, falta de aire repentina, desmayo, síntomas de derrame cerebral o una emergencia médica, llame al 911 inmediatamente.",
        officeLabel: "Oficina de cardiología en Hialeah",
        officeDescription:
            "Atendiendo pacientes de Hialeah, Miami, Miami Lakes, Doral, Hialeah Gardens, Miami Gardens y comunidades cercanas de Miami-Dade.",
        backToServices: "Volver a todos los servicios",
        backHref: " /es/services/",
        floatingAlt: `${service.title.es} con Victor Pazos, MD en Hialeah, FL`,
    },
};

const t = content[currentLanguage];

const pageTitle = service.seo.title[currentLanguage];
const pageDescription = service.seo.description[currentLanguage];
const canonicalPath = service.href[currentLanguage];

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: service.faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question[currentLanguage],
        acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer[currentLanguage],
        },
    })),
};

const serviceSchema = {
    "@context": "https://schema.org",
    "@type": "MedicalBusiness",
    name: service.title[currentLanguage],
    description: service.description[currentLanguage],
    areaServed: "Miami-Dade County",
    address: {
        "@type": "PostalAddress",
        streetAddress: `${contactInfo.address.street} ${contactInfo.address.suite}`,
        addressLocality: contactInfo.address.city,
        addressRegion: contactInfo.address.state,
        postalCode: contactInfo.address.zip,
        addressCountry: contactInfo.address.country,
    },
    telephone: contactInfo.phone.raw,
    medicalSpecialty: "Cardiovascular",
};
---

<MainLayout
    fullTitle
    language={currentLanguage}
    title={pageTitle}
    description={pageDescription}
    canonical={canonicalPath}
    alternateUrls={{
        en: service.href.en,
        es: service.href.es,
    }}
    schema={[
        ...getGlobalSchema(),
        getWebPageSchema({
            title: pageTitle,
            description: pageDescription,
            path: canonicalPath,
        }),
        serviceSchema,
        faqSchema,
    ]}
>
    <section class="relative isolate overflow-hidden section-padding-lg medical-grid-bg">
        <div
            class="pointer-events-none absolute -left-20 top-[12%] -z-10 aspect-square w-[22rem] rounded-full bg-[color-mix(in_srgb,var(--color-secondary)_24%,transparent)] opacity-45 blur-[58px]"
            aria-hidden="true"
        >
        </div>

        <div
            class="pointer-events-none absolute -right-20 bottom-[12%] -z-10 aspect-square w-[24rem] rounded-full bg-[color-mix(in_srgb,var(--color-heart)_14%,transparent)] opacity-45 blur-[58px]"
            aria-hidden="true"
        >
        </div>

        <div class="site-container relative z-10 grid items-center gap-[clamp(2rem,6vw,5rem)] lg:grid-cols-2">
            <div class="grid content-center">
                <nav class="mb-6 flex flex-wrap items-center gap-2 text-sm font-black text-[var(--color-text-soft)]">
                    <a href={t.backHref} class="transition-colors hover:text-[var(--color-secondary)]">
                        {t.servicesLabel}
                    </a>

                    <span aria-hidden="true">/</span>

                    <span class="text-[var(--color-heading)]">
                        {service.shortTitle[currentLanguage]}
                    </span>
                </nav>

                <span class="section-kicker">{service.shortTitle[currentLanguage]}</span>

                <h1 class="max-w-[980px]  text-[clamp(3rem,7vw,6.7rem)] text-[var(--color-heading)] max-[440px]:text-[clamp(2.75rem,15vw,4.25rem)]">
                    {service.title[currentLanguage]}
                </h1>

                <p class="mt-5 max-w-[760px] text-[clamp(1.05rem,1.5vw,1.22rem)] text-[var(--color-text-soft)]">
                    {service.description[currentLanguage]}
                </p>

                <div class="mt-8 flex flex-wrap gap-3 max-md:grid max-md:w-full">
                    <a href={contactInfo.phone.href} class="btn btn-primary">
                        {t.callLabel}
                    </a>

                    <a
                        href={contactInfo.map.googleMapsUrl}
                        class="btn btn-secondary"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {t.directionsLabel}
                    </a>
                </div>
            </div>

            <div class="relative mx-auto w-full max-w-[420px] lg:mx-0">
                <div
                    class="pointer-events-none absolute -inset-6 rounded-[2.5rem] bg-[color-mix(in_srgb,var(--color-secondary)_18%,transparent)] blur-3xl"
                    aria-hidden="true"
                >
                </div>

                <div class="service-detail-slider service-detail-floating relative aspect-[4/5] overflow-hidden rounded-[2rem] border border-[color-mix(in_srgb,var(--color-secondary)_28%,var(--color-border))] bg-[color-mix(in_srgb,var(--color-surface)_76%,transparent)] shadow-[var(--shadow-card)]">
                    {
                        serviceImages.map((image, index) => (
                            <figure
                                class="service-detail-slide absolute inset-0"
                                style={`--slide-delay: ${index * 5}s; --slide-duration: ${slideDuration}s;`}
                            >
                                <img
                                    src={image.src}
                                    alt={image.alt[currentLanguage]}
                                    class="h-full w-full object-cover"
                                    loading={index === 0 ? "eager" : "lazy"}
                                    decoding="async"
                                />
                            </figure>
                        ))
                    }

                    <div
                        class="absolute inset-0 bg-gradient-to-t from-[color-mix(in_srgb,var(--color-bg)_88%,transparent)] via-[color-mix(in_srgb,var(--color-bg)_24%,transparent)] to-transparent"
                        aria-hidden="true"
                    >
                    </div>

                    <div
                        class="absolute inset-0 bg-[radial-gradient(circle_at_50%_28%,transparent,color-mix(in_srgb,var(--color-bg)_18%,transparent)_72%)]"
                        aria-hidden="true"
                    >
                    </div>

                    <div class="absolute left-4 top-4 z-10 flex gap-2" aria-hidden="true">
                        {
                            serviceImages.map((_, index) => (
                                <span
                                    class="service-detail-slider-dot block h-1.5 w-8 rounded-full bg-white/45"
                                    style={`--dot-delay: ${index * 5}s; --slide-duration: ${slideDuration}s;`}
                                />
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section-padding-sm">
        <div class="site-container glow-panel grid items-start gap-[clamp(1.25rem,4vw,3rem)] p-[clamp(1.25rem,3vw,2rem)] max-md:rounded-[1.65rem] lg:grid-cols-[minmax(0,0.72fr)_minmax(0,1fr)]">
            <div>
                <span class="section-kicker">{t.overviewLabel}</span>

                <h2 class="max-w-[640px] text-[clamp(2.1rem,4.8vw,4.4rem)] text-[var(--color-heading)]">
                    {service.shortTitle[currentLanguage]}
                </h2>
            </div>

            <p class="text-[clamp(1rem,1.35vw,1.12rem)] text-[var(--color-text-soft)]">
                {service.overview[currentLanguage]}
            </p>
        </div>
    </section>

    <section class="relative isolate overflow-hidden section-padding">
        <div
            class="pointer-events-none absolute -right-20 top-[10%] -z-10 aspect-square w-[22rem] rounded-full bg-[color-mix(in_srgb,var(--color-secondary)_22%,transparent)] opacity-45 blur-[58px]"
            aria-hidden="true"
        >
        </div>

        <div class="site-container">
            <div class="mb-[clamp(1.75rem,4vw,3rem)] grid gap-[clamp(1rem,4vw,3rem)]">
                <div>
                    <span class="section-kicker">{t.reasonsKicker}</span>

                    <h2 class="text-[clamp(2.25rem,5vw,4.8rem)] text-[var(--color-heading)]">
                        {t.reasonsTitle}
                    </h2>
                </div>

                <p class="text-[clamp(1rem,1.35vw,1.12rem)] text-[var(--color-text-soft)]">
                    {service.shortDescription[currentLanguage]}
                </p>
            </div>

            <div class="grid gap-4 md:grid-cols-3">
                {
                    service.reasonsToSeekCare.map((item, index) => (
                        <article
                            class="medical-card group relative min-h-64 overflow-hidden p-[clamp(1rem,2vw,1.25rem)] animate-fade-up max-md:min-h-0"
                            style={`animation-delay: ${index * 80}ms;`}
                        >
                            <div
                                class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                                style="background: radial-gradient(circle at top right, color-mix(in srgb, var(--color-heart) 16%, transparent), transparent 12rem), radial-gradient(circle at bottom left, color-mix(in srgb, var(--color-secondary) 14%, transparent), transparent 12rem);"
                                aria-hidden="true"
                            >
                            </div>

                            <div class="relative z-10">
                                <span class="font-heading text-4xl font-extrabold text-[color-mix(in_srgb,var(--color-accent)_76%,var(--color-text-muted))] opacity-60">
                                    {String(index + 1).padStart(2, "0")}
                                </span>

                                <h3 class="mt-8 font-heading text-[clamp(1.45rem,2.4vw,2.15rem)] text-[var(--color-heading)]">
                                    {item.title[currentLanguage]}
                                </h3>

                                <p class="mt-3 text-base text-[var(--color-text-soft)]">
                                    {item.description[currentLanguage]}
                                </p>
                            </div>
                        </article>
                    ))
                }
            </div>

            <p class="mt-[clamp(1.25rem,3vw,2rem)] rounded-[1.25rem] border border-[color-mix(in_srgb,var(--color-heart)_28%,var(--color-border))] bg-[color-mix(in_srgb,var(--color-heart-soft)_38%,transparent)] p-4 text-sm font-extrabold text-[var(--color-heart)]">
                {t.emergencyNote}
            </p>
        </div>
    </section>

    <section class="section-padding">
        <div class="site-container grid gap-[clamp(2rem,6vw,5rem)] lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)]">
            <div class="lg:sticky lg:top-28 lg:self-start">
                <span class="section-kicker">{t.expectKicker}</span>

                <h2 class="max-w-[720px] text-[clamp(2.25rem,5vw,4.8rem)] text-[var(--color-heading)]">
                    {t.expectTitle}
                </h2>
            </div>

            <div class="relative grid gap-4 before:absolute before:bottom-4 before:left-6 before:top-4 before:w-px before:bg-[linear-gradient(180deg,transparent,color-mix(in_srgb,var(--color-secondary)_38%,var(--color-border)),color-mix(in_srgb,var(--color-accent)_34%,var(--color-border)),transparent)] before:content-['']">
                {
                    service.whatToExpect.map((item, index) => (
                        <article
                            class="medical-card relative grid grid-cols-[auto_1fr] gap-4 overflow-hidden p-[clamp(1rem,2vw,1.2rem)] animate-fade-up"
                            style={`animation-delay: ${index * 80}ms;`}
                        >
                            <span class="relative z-10 grid size-12 place-items-center rounded-2xl border border-[color-mix(in_srgb,var(--color-secondary)_34%,var(--color-border))] bg-[color-mix(in_srgb,var(--color-surface)_86%,transparent)] font-heading text-lg font-extrabold text-[var(--color-secondary)] shadow-[0_14px_34px_rgba(15,23,42,0.07)]">
                                {String(index + 1).padStart(2, "0")}
                            </span>

                            <div class="relative z-10">
                                <h3 class="font-heading text-[clamp(1.35rem,2vw,1.85rem)] text-[var(--color-heading)]">
                                    {item.title[currentLanguage]}
                                </h3>

                                <p class="mt-2 text-[0.96rem] text-[var(--color-text-soft)]">
                                    {item.description[currentLanguage]}
                                </p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="relative isolate overflow-hidden section-padding">
        <div
            class="pointer-events-none absolute -left-20 bottom-[8%] -z-10 aspect-square w-[20rem] rounded-full bg-[color-mix(in_srgb,var(--color-heart)_14%,transparent)] opacity-45 blur-[58px]"
            aria-hidden="true"
        >
        </div>

        <div class="site-container grid gap-[clamp(2rem,6vw,5rem)] lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)]">
            <div class="lg:sticky lg:top-28 lg:self-start">
                <span class="section-kicker">{t.faqKicker}</span>

                <h2 class="max-w-[720px] text-[clamp(2.25rem,5vw,4.8rem)] text-[var(--color-heading)]">
                    {t.faqTitle}
                </h2>
            </div>

            <div class="grid gap-4">
                {
                    service.faqs.map((faq, index) => (
                        <details
                            class="medical-card group overflow-hidden p-0 animate-fade-up"
                            style={`animation-delay: ${index * 80}ms;`}
                            open={index === 0}
                        >
                            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-[clamp(1rem,2vw,1.2rem)] [&::-webkit-details-marker]:hidden">
                                <span class="font-heading text-[clamp(1.25rem,2vw,1.65rem)] font-extrabold text-[var(--color-heading)]">
                                    {faq.question[currentLanguage]}
                                </span>

                                <span class="grid size-10 shrink-0 place-items-center rounded-full border border-[color-mix(in_srgb,var(--color-secondary)_28%,var(--color-border))] bg-[color-mix(in_srgb,var(--color-surface)_78%,transparent)] text-[var(--color-secondary)] transition-transform duration-300 group-open:rotate-45 group-open:text-[var(--color-heart)]">
                                    <svg
                                        viewBox="0 0 24 24"
                                        width="18"
                                        height="18"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        aria-hidden="true"
                                    >
                                        <path d="M12 5v14" />
                                        <path d="M5 12h14" />
                                    </svg>
                                </span>
                            </summary>

                            <p class="px-[clamp(1rem,2vw,1.2rem)] pb-[clamp(1rem,2vw,1.2rem)] text-[0.98rem] text-[var(--color-text-soft)]">
                                {faq.answer[currentLanguage]}
                            </p>
                        </details>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section-padding-sm">
        <div class="site-container">
            <div class="glow-panel grid items-center gap-5 p-[clamp(1.25rem,3vw,2rem)] max-md:rounded-[1.65rem] lg:grid-cols-[1fr_auto]">
                <div>
                    <span class="section-kicker">{t.appointmentKicker}</span>

                    <h2 class="text-[clamp(2rem,4vw,3.75rem)] text-[var(--color-heading)]">
                        {t.appointmentTitle}
                    </h2>

                    <p class="mt-3 max-w-[720px] text-base text-[var(--color-text-soft)]">
                        {t.appointmentDescription}
                    </p>
                </div>

                <a href={contactInfo.phone.href} class="btn btn-primary max-lg:w-fit max-md:w-full">
                    {t.callLabel}
                </a>
            </div>
        </div>
    </section>

    <section class="section-padding">
        <div class="site-container">
            <div class="mb-[clamp(1.75rem,4vw,3rem)] max-w-[780px]">
                <span class="section-kicker">{t.relatedKicker}</span>

                <h2 class="text-[clamp(2.25rem,5vw,4.8rem)] text-[var(--color-heading)]">
                    {t.relatedTitle}
                </h2>
            </div>

            <div class="grid gap-4 md:grid-cols-3">
                {
                    relatedServices.map((related, index) => {
                        const RelatedIcon = related.icon;

                        return (
                            <a
                                href={getCardiologyServiceHref(related, currentLanguage)}
                                class="medical-card group relative overflow-hidden p-[clamp(1rem,2vw,1.25rem)] text-inherit animate-fade-up"
                                style={`animation-delay: ${index * 80}ms;`}
                                aria-label={`${t.exploreService}: ${related.title[currentLanguage]}`}
                            >
                                <div
                                    class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                                    style="background: radial-gradient(circle at top right, color-mix(in srgb, var(--color-secondary) 18%, transparent), transparent 12rem);"
                                    aria-hidden="true"
                                >
                                </div>

                                <div class="relative z-10">
                                    <span class="grid size-12 p-2 place-items-center rounded-2xl border border-[color-mix(in_srgb,var(--color-secondary)_32%,var(--color-border))] bg-[color-mix(in_srgb,var(--color-surface)_76%,transparent)] text-[var(--color-secondary)]">
                                        <RelatedIcon />
                                    </span>

                                    <h3 class="mt-6 font-heading text-[clamp(1.35rem,2vw,1.85rem)] text-[var(--color-heading)]">
                                        {related.title[currentLanguage]}
                                    </h3>

                                    <p class="mt-3 text-sm  text-[var(--color-text-soft)]">
                                        {related.shortDescription[currentLanguage]}
                                    </p>

                                    <span class="mt-5 inline-flex w-fit items-center gap-2 text-sm font-black text-[var(--color-secondary)] transition-transform duration-300 group-hover:translate-x-1">
                                        {t.exploreService}

                                        <svg
                                            viewBox="0 0 24 24"
                                            width="18"
                                            height="18"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            aria-hidden="true"
                                        >
                                            <path d="M5 12h14" />
                                            <path d="m12 5 7 7-7 7" />
                                        </svg>
                                    </span>
                                </div>
                            </a>
                        );
                    })
                }
            </div>
        </div>
    </section>
</MainLayout>

<style>
    .service-detail-floating {
        animation: service-detail-floating 6.5s ease-in-out infinite;
        will-change: transform;
    }

    .service-detail-floating :global(svg) {
        width: 3.25rem;
        height: 3.25rem;
    }

    .service-detail-slide {
        opacity: 0;
        animation-name: service-detail-slide-fade;
        animation-duration: var(--slide-duration);
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
        animation-delay: var(--slide-delay);
        will-change: opacity;
    }

    .service-detail-slide img {
        transform: scale(1.06);
        transform-origin: center center;
        animation-name: service-detail-ken-burns;
        animation-duration: var(--slide-duration);
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
        animation-delay: var(--slide-delay);
        will-change: transform;
    }

    .service-detail-slider-dot {
        opacity: 0.35;
        transform: scaleX(0.2);
        transform-origin: left center;
        animation-name: service-detail-dot-progress;
        animation-duration: var(--slide-duration);
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
        animation-delay: var(--dot-delay);
        will-change: transform, opacity;
    }

    @keyframes service-detail-floating {
        0%,
        100% {
            transform: translate3d(0, 0, 0) rotate(-1deg);
        }

        50% {
            transform: translate3d(0, -14px, 0) rotate(1deg);
        }
    }

    @keyframes service-detail-slide-fade {
        0% {
            opacity: 0;
        }

        5% {
            opacity: 1;
        }

        31% {
            opacity: 1;
        }

        36% {
            opacity: 0;
        }

        100% {
            opacity: 0;
        }
    }

    @keyframes service-detail-ken-burns {
        0% {
            transform: scale(1.06) translate3d(0, 0, 0);
        }

        31% {
            transform: scale(1.18) translate3d(-2%, -1.5%, 0);
        }

        100% {
            transform: scale(1.18) translate3d(-2%, -1.5%, 0);
        }
    }

    @keyframes service-detail-dot-progress {
        0% {
            opacity: 0.35;
            transform: scaleX(0.2);
        }

        5% {
            opacity: 1;
            transform: scaleX(0.35);
        }

        31% {
            opacity: 1;
            transform: scaleX(1);
        }

        36% {
            opacity: 0.35;
            transform: scaleX(0.2);
        }

        100% {
            opacity: 0.35;
            transform: scaleX(0.2);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .service-detail-floating,
        .service-detail-slide,
        .service-detail-slide img,
        .service-detail-slider-dot {
            animation: none;
        }

        .service-detail-slide:first-child {
            opacity: 1;
        }

        .service-detail-slide img {
            transform: scale(1);
        }
    }
</style>