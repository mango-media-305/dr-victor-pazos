---
import { ArrowRight, MapPin, Phone } from "lucide-astro";

import MainLayout from "../../layouts/MainLayout.astro";
import {
    cardiologyServices,
    getCardiologyServiceHref,
} from "../../data/services/cardiologyServices";
import { contactInfo } from "../../data/site/contact";
import { servicesIndexMetadata } from "../../data/seo/pageMetadata";
import { getGlobalSchema, getWebPageSchema } from "../../data/seo/schema";

const currentLanguage = "en";
const metadata = servicesIndexMetadata;

const heroFloatingImage = "/images/services/cardiology-services-floating.webp";

const services = cardiologyServices.sort((a, b) => a.priority - b.priority);

const content = {
    kicker: "Cardiology services",
    title:
        "Cardiology care for symptoms, testing, prevention, and ongoing heart conditions.",
    description:
        "Explore cardiology services available through Victor Pazos, MD. PA. in Hialeah, FL, serving patients across Miami-Dade County.",
    introKicker: "Patient-focused care",
    introTitle: "Heart care starts with understanding what you need.",
    introDescription:
        "Patients may contact a cardiologist for symptoms such as chest discomfort, palpitations, shortness of breath, high blood pressure, abnormal EKG results, or known heart disease. These service pages are designed to help patients understand common reasons to seek cardiology evaluation and how the office may help.",
    callLabel: contactInfo.appointment.primaryCta.en,
    directionsLabel: contactInfo.map.directionsLabel.en,
    viewService: "Explore service",
    emergencyNote:
        "If you are experiencing severe chest pain, sudden shortness of breath, fainting, stroke symptoms, or a medical emergency, call 911 immediately.",
    officeLabel: "Hialeah cardiology office",
    officeDescription:
        "Located in Hialeah and serving patients from Miami, Miami Lakes, Doral, Hialeah Gardens, Miami Gardens, and nearby Miami-Dade communities.",
    bottomKicker: "Request an appointment",
    bottomTitle: "Need help choosing the right cardiology service?",
    bottomDescription:
        "Call the office to request an appointment or ask which type of cardiology evaluation may be appropriate for your concern.",
};
---

<MainLayout
    fullTitle
    title={metadata.title.en}
    description={metadata.description.en}
    canonical={metadata.canonical.en}
    alternateUrls={{
        en: metadata.canonical.en,
        es: metadata.canonical.es,
    }}
    schema={[
        ...getGlobalSchema(),
        getWebPageSchema({
        title: metadata.title.en,
        description: metadata.description.en,
        path: metadata.canonical.en,
        }),
    ]}
>
    <section
        class="relative isolate overflow-hidden section-padding-lg medical-grid-bg"
    >
        <div
        class="pointer-events-none absolute -left-20 top-[12%] -z-10 aspect-square w-[22rem] rounded-full bg-[color-mix(in_srgb,var(--color-secondary)_24%,transparent)] blur-[58px] opacity-45"
        aria-hidden="true"
        >
        </div>

        <div
        class="pointer-events-none absolute -right-20 bottom-[12%] -z-10 aspect-square w-[24rem] rounded-full bg-[color-mix(in_srgb,var(--color-heart)_14%,transparent)] blur-[58px] opacity-45"
        aria-hidden="true"
        >
        </div>

        <div
        class="site-container relative z-10 grid items-center gap-[clamp(2rem,6vw,5rem)] lg:grid-cols-2"
        >
            <div class="grid content-center">
                <span class="section-kicker">{content.kicker}</span>

                <h1
                    class="text-[clamp(2rem,7vw,5rem)]   text-[var(--color-heading)]"
                >
                {content.title}
                </h1>

                <p
                class="mt-5 max-w-[760px] text-[clamp(1.05rem,1.5vw,1.22rem)] text-[var(--color-text-soft)]"
                >
                {content.description}
                </p>

                <div class="mt-8 flex flex-wrap gap-3 max-md:grid max-md:w-full">
                <a href={contactInfo.phone.href} class="btn btn-primary">
                    <Phone size={18} strokeWidth={2} aria-hidden="true" />
                    {content.callLabel}
                </a>

                <a
                    href={contactInfo.map.googleMapsUrl}
                    class="btn btn-secondary"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <MapPin size={18} strokeWidth={2} aria-hidden="true" />
                    {content.directionsLabel}
                </a>
                </div>
            </div>

            <div class="relative mx-auto w-full max-w-[420px] lg:mx-0 hidden md:block">
                <div
                class="pointer-events-none absolute -inset-6 rounded-[2.5rem] bg-[color-mix(in_srgb,var(--color-secondary)_18%,transparent)] blur-3xl"
                aria-hidden="true"
                >
                </div>

                <div
                class="services-floating-image relative aspect-[4/5] overflow-hidden rounded-[2rem]"
                >
                    <img
                        src={heroFloatingImage}
                        alt="Cardiology care and heart health evaluation"
                        class="h-full w-full object-cover"
                        loading="eager"
                        decoding="async"
                    />
                </div>
            </div>
        </div>
    </section>

    <section class="section-padding-sm">
        <div
        class="site-container glow-panel grid items-end gap-[clamp(1.25rem,4vw,3rem)] p-[clamp(1.25rem,3vw,2rem)] lg:grid-cols-1"
        >
        <div>
            <span class="section-kicker">{content.introKicker}</span>

            <h2
            class="text-[clamp(2.1rem,4.8vw,4.4rem)] text-[var(--color-heading)]"
            >
            {content.introTitle}
            </h2>
        </div>

        <p
            class="text-[clamp(1rem,1.35vw,1.12rem)] text-(--color-text-soft)"
        >
            {content.introDescription}
        </p>
        </div>
    </section>

    <section class="relative isolate overflow-hidden section-padding">
        <div
        class="pointer-events-none absolute -right-20 top-[10%] -z-10 aspect-square w-[22rem] rounded-full bg-[color-mix(in_srgb,var(--color-secondary)_22%,transparent)] blur-[58px] opacity-45"
        aria-hidden="true"
        >
        </div>

        <div
        class="pointer-events-none absolute -left-20 bottom-[8%] -z-10 aspect-square w-[20rem] rounded-full bg-[color-mix(in_srgb,var(--color-heart)_14%,transparent)] blur-[58px] opacity-45"
        aria-hidden="true"
        >
        </div>

        <div class="site-container">
        <div class="relative z-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            {
            services.map((service, index) => {
                const Icon = service.icon;

                return (
                        <a
                            href={getCardiologyServiceHref(service, currentLanguage)}
                            class="service-card-link medical-card group grid min-h-72 content-between p-[clamp(1.1rem,2vw,1.35rem)] text-inherit max-[680px]:min-h-0"
                            style={`--service-delay: ${index * 80}ms;`}
                            aria-label={`${content.viewService}: ${service.title[currentLanguage]}`}
                        >
                            <div class="relative z-[1] flex items-center justify-between gap-4">
                                <span
                                    class="inline-grid size-[3.2rem] place-items-center rounded-[1.05rem] border border-[color-mix(in_srgb,var(--color-secondary)_32%,var(--color-border))] bg-[color-mix(in_srgb,var(--color-surface)_76%,transparent)] text-[var(--color-secondary)] shadow-[0_14px_34px_rgba(15,23,42,0.07)]"
                                    aria-hidden="true"
                                >
                                    <Icon class="h-7 w-7" />
                                </span>
                            </div>

                            <div class="relative z-[1] mt-[2.4rem] grid gap-3 max-[680px]:mt-7">
                                <h4
                                    class="font-heading text-md text-[var(--color-heading)]"
                                >
                                    {service.shortTitle[currentLanguage]}
                                </h4>

                                <p class="text-[0.96rem] text-[var(--color-text-soft)]">
                                    {service.shortDescription[currentLanguage]}
                                </p>
                            </div>

                            <span
                                class="relative z-[1] mt-[1.35rem] inline-flex w-fit items-center gap-[0.45rem] text-[0.88rem] font-black uppercase text-[var(--color-secondary)] transition-[color,transform] duration-200 group-hover:translate-x-1 group-hover:text-[var(--color-accent-dark)] dark:group-hover:text-[var(--color-accent)]"
                            >
                                {content.viewService}

                                <ArrowRight size={18} strokeWidth={2} aria-hidden="true" />
                            </span>
                        </a>
                    );
            })
            }
        </div>

        <p
            class="relative z-10 mt-[clamp(1.25rem,3vw,2rem)] rounded-[1.25rem] border border-[color-mix(in_srgb,var(--color-heart)_28%,var(--color-border))] bg-[color-mix(in_srgb,var(--color-heart-soft)_38%,transparent)] p-4 text-sm font-extrabold text-[var(--color-heart)]"
        >
            {content.emergencyNote}
        </p>
        </div>
    </section>

    <section class="section-padding-sm">
        <div class="site-container">
        <div
            class="glow-panel grid items-center gap-5 p-[clamp(1.25rem,3vw,2rem)] lg:grid-cols-[1fr_auto]"
        >
            <div>
            <span class="section-kicker">{content.bottomKicker}</span>

            <h2
                class="text-[clamp(2rem,4vw,3.75rem)] text-[var(--color-heading)]"
            >
                {content.bottomTitle}
            </h2>

            <p
                class="mt-3 max-w-[720px] text-base text-[var(--color-text-soft)]"
            >
                {content.bottomDescription}
            </p>
            </div>

            <a
            href={contactInfo.phone.href}
            class="btn btn-primary max-lg:w-fit max-md:w-full"
            >
            {content.callLabel}
            </a>
        </div>
        </div>
    </section>
    <style>
        .services-floating-image {
            animation: services-floating-image 6.5s ease-in-out infinite;
            will-change: transform;
        }

        @keyframes services-floating-image {
            0%,
            100% {
                transform: translate3d(0, 0, 0) rotate(-1deg);
            }

            50% {
                transform: translate3d(0, -14px, 0) rotate(1deg);
            }
        }

        @media (prefers-reduced-motion: reduce) {
            .services-floating-image {
                animation: none;
            }
        }
    </style>
</MainLayout>
