---
// src/components/global/Header.astro

import ThemeToggle from "./ThemeToggle.astro";

import { siteConfig, type LanguageCode } from "../../data/site/siteConfig";
import { contactInfo } from "../../data/site/contact";
import {
    ctaNavigation,
    mainNavigation,
    mobileNavigationLabels,
} from "../../data/site/navigation";
import {
    getAlternateLanguagePath,
    getLanguageFromUrl,
    languageShortLabels,
} from "../../data/i18n/language";

interface Props {
    language?: LanguageCode;
}

const { language } = Astro.props as Props;
const currentLanguage = language ?? getLanguageFromUrl(Astro.url.pathname);
const alternatePath = getAlternateLanguagePath(Astro.url.pathname);
const alternateLanguage = currentLanguage === "en" ? "es" : "en";
---

<header class="site-header" data-site-header>
    <div class="header-shell">
        <a
            href={currentLanguage === "es" ? "/es/" : "/"}
            class="brand-link"
            aria-label={`${siteConfig.name} home`}
        >
            <span class="brand-logo-wrap" aria-hidden="true">
                <img
                    src={siteConfig.assets.logo.light}
                    alt=""
                    class="brand-logo-mark brand-logo-light"
                    width="48"
                    height="48"
                />

                <img
                    src={siteConfig.assets.logo.dark}
                    alt=""
                    class="brand-logo-mark brand-logo-dark"
                    width="48"
                    height="48"
                />
            </span>

            <span class="brand-text">
                <strong>Victor Pazos, MD. PA.</strong>
                <small>Cardiology</small>
            </span>
        </a>

        <nav class="desktop-nav" aria-label="Primary navigation">
        {
            mainNavigation.map((item) => (
            <a href={item.href[currentLanguage]} class="nav-link">
                {item.label[currentLanguage]}
            </a>
            ))
        }
        </nav>

        <div class="header-actions">
        <a
            href={alternatePath}
            class="language-pill"
            aria-label={`Switch to ${
            alternateLanguage === "es" ? "Spanish" : "English"
            }`}
        >
            {languageShortLabels[alternateLanguage]}
        </a>

        <ThemeToggle
            label={currentLanguage === "es" ? "Cambiar tema" : "Toggle theme"}
        />

        <a href={contactInfo.phone.href} class="btn btn-primary header-call">
            <span>{ctaNavigation.call.label[currentLanguage]}</span>
        </a>

        <button
            type="button"
            class="mobile-menu-button"
            aria-label={mobileNavigationLabels.openMenu[currentLanguage]}
            aria-expanded="false"
            aria-controls="mobile-menu"
            data-menu-toggle
        >
            <span></span>
            <span></span>
            <span></span>
        </button>
        </div>
    </div>

    <div id="mobile-menu" class="mobile-menu" data-mobile-menu hidden>
        <div class="mobile-menu-panel">
        <div class="mobile-menu-top">
            <span class="mobile-menu-label">
            {mobileNavigationLabels.menu[currentLanguage]}
            </span>

            <button
            type="button"
            class="mobile-close"
            aria-label={mobileNavigationLabels.closeMenu[currentLanguage]}
            data-menu-close
            >
            ×
            </button>
        </div>

        <nav class="mobile-nav" aria-label="Mobile navigation">
            {
            mainNavigation.map((item) => (
                <a href={item.href[currentLanguage]} class="mobile-nav-link">
                <span>{item.label[currentLanguage]}</span>

                {item.description && (
                    <small>{item.description[currentLanguage]}</small>
                )}
                </a>
            ))
            }
        </nav>

        <div class="mobile-menu-actions">
            <a href={contactInfo.phone.href} class="btn btn-primary">
                {ctaNavigation.call.label[currentLanguage]}
            </a>

            <a href={ctaNavigation.appointment.href[currentLanguage]} class="btn btn-secondary">
                {ctaNavigation.appointment.label[currentLanguage]}
            </a>
        </div>

        <div class="mobile-contact-card">
            <strong>{contactInfo.practiceName}</strong>
            <span>{contactInfo.address.display}</span>
            <a href={contactInfo.phone.href}>{contactInfo.phone.label}</a>
        </div>
        </div>
    </div>
</header>

<script>
    const header = document.querySelector("[data-site-header]");
    const menu = document.querySelector("[data-mobile-menu]");
    const toggle = document.querySelector("[data-menu-toggle]");
    const closeButton = document.querySelector("[data-menu-close]");
    const mobileLinks = document.querySelectorAll(".mobile-nav-link");

    function openMenu() {
        if (!menu || !toggle) return;

        menu.removeAttribute("hidden");
        toggle.setAttribute("aria-expanded", "true");
        document.documentElement.classList.add("menu-open");
    }

    function closeMenu() {
        if (!menu || !toggle) return;

        menu.setAttribute("hidden", "");
        toggle.setAttribute("aria-expanded", "false");
        document.documentElement.classList.remove("menu-open");
    }

    toggle?.addEventListener("click", () => {
        const isExpanded = toggle.getAttribute("aria-expanded") === "true";

        if (isExpanded) {
        closeMenu();
        } else {
        openMenu();
        }
    });

    closeButton?.addEventListener("click", closeMenu);

    mobileLinks.forEach((link) => {
        link.addEventListener("click", closeMenu);
    });

    window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
        closeMenu();
        }
    });

    window.addEventListener("scroll", () => {
        if (!header) return;

        header.classList.toggle("is-scrolled", window.scrollY > 16);
    });
</script>

<style>
    .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        padding: 1rem;
        transition:
        padding 220ms var(--motion-smooth),
        background var(--theme-transition);
    }

    .header-shell {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 1rem;
        width: min(100% - 1rem, 1240px);
        min-height: 4.35rem;
        margin-inline: auto;
        border: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
        border-radius: 999px;
        padding: 0.45rem 0.55rem 0.45rem 1rem;
        background: color-mix(in srgb, var(--color-surface) 82%, transparent);
        box-shadow: 0 18px 55px rgba(15, 23, 42, 0.07);
        backdrop-filter: blur(22px);
        transition:
        border-color var(--theme-transition),
        background var(--theme-transition),
        box-shadow var(--theme-transition),
        transform 220ms var(--motion-smooth);
    }

    .site-header.is-scrolled {
        padding-block: 0.65rem;
    }

    .site-header.is-scrolled .header-shell {
        box-shadow: var(--shadow-card);
    }

    .brand-link {
        display: inline-flex;
        align-items: center;
        min-width: 0;
    }

    .brand-logo {
        width: clamp(9.75rem, 15vw, 12rem);
        height: auto;
        object-fit: contain;
    }

    .desktop-nav {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.25rem;
    }

    .nav-link {
        position: relative;
        border-radius: 999px;
        padding: 0.72rem 0.9rem;
        color: var(--color-text);
        font-size: 0.9rem;
        font-weight: 800;
        transition:
        color var(--theme-transition),
        background var(--theme-transition);
    }

    .nav-link:hover {
        color: var(--color-heading);
        background: color-mix(in srgb, var(--color-secondary-soft) 46%, transparent);
    }

    .header-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.45rem;
    }

    .language-pill {
        display: inline-grid;
        place-items: center;
        width: 2.75rem;
        height: 2.75rem;
        border: 1px solid var(--color-border);
        border-radius: 999px;
        color: var(--color-heading);
        background: color-mix(in srgb, var(--color-surface) 86%, transparent);
        font-size: 0.8rem;
        font-weight: 900;
        box-shadow: 0 12px 32px rgba(15, 23, 42, 0.06);
        transition:
        transform 220ms var(--motion-smooth),
        border-color var(--theme-transition),
        background var(--theme-transition);
    }

    .language-pill:hover {
        transform: translateY(-2px);
        border-color: color-mix(
        in srgb,
        var(--color-secondary) 42%,
        var(--color-border)
        );
    }

    .header-call {
        min-height: 2.75rem;
        padding-inline: 1.1rem;
        font-size: 0.88rem;
    }

    .mobile-menu-button {
        display: none;
        width: 2.75rem;
        height: 2.75rem;
        place-items: center;
        gap: 0.26rem;
        border: 1px solid var(--color-border);
        border-radius: 999px;
        color: var(--color-heading);
        background: color-mix(in srgb, var(--color-surface) 86%, transparent);
    }

    .mobile-menu-button span {
        display: block;
        width: 1.05rem;
        height: 2px;
        border-radius: 99px;
        background: currentColor;
    }

    .mobile-menu {
        position: fixed;
        inset: 0;
        z-index: 120;
        padding: 1rem;
        background: rgba(6, 21, 34, 0.38);
        backdrop-filter: blur(14px);
    }

    .mobile-menu-panel {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-height: calc(100vh - 2rem);
        overflow-y: auto;
        border: 1px solid var(--color-border);
        border-radius: 2rem;
        padding: 1rem;
        background:
        radial-gradient(
            circle at top right,
            color-mix(in srgb, var(--color-secondary) 12%, transparent),
            transparent 16rem
        ),
        var(--color-surface);
        box-shadow: var(--shadow-card);
    }

    .mobile-menu-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .mobile-menu-label {
        color: var(--color-heading);
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 800;
    }

    .mobile-close {
        display: inline-grid;
        place-items: center;
        width: 2.6rem;
        height: 2.6rem;
        border: 1px solid var(--color-border);
        border-radius: 999px;
        color: var(--color-heading);
        background: color-mix(in srgb, var(--color-surface-soft) 74%, transparent);
        font-size: 1.65rem;
        line-height: 1;
    }

    .mobile-nav {
        display: grid;
        gap: 0.65rem;
    }

    .mobile-nav-link {
        display: grid;
        gap: 0.25rem;
        border: 1px solid var(--color-border);
        border-radius: 1.2rem;
        padding: 1rem;
        background: color-mix(in srgb, var(--color-surface-soft) 54%, transparent);
    }

    .mobile-nav-link span {
        color: var(--color-heading);
        font-weight: 900;
    }

    .mobile-nav-link small {
        color: var(--color-text-soft);
        font-size: 0.84rem;
        line-height: 1.5;
    }

    .mobile-menu-actions {
        display: grid;
        gap: 0.65rem;
    }

    .mobile-contact-card {
        display: grid;
        gap: 0.35rem;
        border: 1px solid var(--color-border);
        border-radius: 1.25rem;
        padding: 1rem;
        color: var(--color-text-soft);
        background: color-mix(in srgb, var(--color-secondary-soft) 34%, transparent);
        font-size: 0.9rem;
        line-height: 1.5;
    }

    .mobile-contact-card strong {
        color: var(--color-heading);
    }

    .mobile-contact-card a {
        width: fit-content;
        color: var(--color-secondary);
        font-weight: 900;
    }

    :global(.menu-open) {
        overflow: hidden;
    }

    @media (max-width: 1080px) {
        .desktop-nav {
        display: none;
        }

        .header-shell {
        grid-template-columns: auto 1fr;
        }

        .mobile-menu-button {
        display: inline-grid;
        }
    }

    @media (max-width: 720px) {
        .site-header {
        padding: 0.65rem;
        }

        .header-shell {
        width: 100%;
        min-height: 4rem;
        padding: 0.4rem 0.45rem 0.4rem 0.75rem;
        }

        .brand-logo {
        width: 9.35rem;
        }

        .header-call {
        display: none;
        }

        .language-pill,
        .mobile-menu-button {
        width: 2.55rem;
        height: 2.55rem;
        }
    }

    @media (max-width: 390px) {
        .brand-logo {
        width: 8.25rem;
        }

        .header-actions {
        gap: 0.3rem;
        }
    }

    .brand-link {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        min-width: 0;
    }

    .brand-logo-wrap {
        position: relative;
        display: inline-grid;
        place-items: center;
        width: 3rem;
        height: 3rem;
        flex: 0 0 auto;
    }

    .brand-logo-mark {
        grid-area: 1 / 1;
        width: 3rem;
        height: 3rem;
        object-fit: contain;
        transition:
            opacity 180ms ease,
            transform 220ms var(--motion-smooth);
    }

    /* Light mode */
    .brand-logo-light {
        opacity: 1;
        transform: scale(1);
    }

    .brand-logo-dark {
        opacity: 0;
        transform: scale(0.96);
    }

    /* Dark mode */
    :global(.dark) .brand-logo-light {
        opacity: 0;
        transform: scale(0.96);
    }

    :global(.dark) .brand-logo-dark {
        opacity: 1;
        transform: scale(1);
    }

    .brand-text {
        display: grid;
        gap: 0.1rem;
        line-height: 1;
    }

    .brand-text strong {
        color: var(--color-heading);
        font-family: var(--font-heading);
        font-size: 1.05rem;
        letter-spacing: -0.03em;
    }

    .brand-text small {
        color: var(--color-text-soft);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }
</style>