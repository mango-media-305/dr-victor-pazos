---
import ThemeToggle from "./ThemeToggle.astro";
import { Menu as MenuIcon, X as XIcon } from "lucide-astro";

import { siteConfig, type LanguageCode } from "../../data/site/siteConfig";
import { contactInfo } from "../../data/site/contact";
import {
    ctaNavigation,
    mainNavigation,
    mobileNavigationLabels,
} from "../../data/site/navigation";
import {
    getAlternateLanguagePath,
    getLanguageFromUrl,
    languageShortLabels,
} from "../../data/i18n/language";

interface Props {
    language?: LanguageCode;
}

const { language } = Astro.props as Props;

const currentLanguage = language ?? getLanguageFromUrl(Astro.url.pathname);
const alternatePath = getAlternateLanguagePath(Astro.url.pathname);
const alternateLanguage = currentLanguage === "en" ? "es" : "en";
---

<header
    class="site-header sticky top-0 z-[100] p-4 transition-[padding,background] duration-200 max-[720px]:p-[0.65rem]"
    data-site-header
>
    <div
        class="header-shell mx-auto grid min-h-[4.35rem] w-[min(100%-1rem,1240px)] grid-cols-[auto_1fr_auto] items-center gap-4 rounded-full border border-[color-mix(in_srgb,var(--color-border)_82%,transparent)] bg-[color-mix(in_srgb,var(--color-surface)_82%,transparent)] py-[0.45rem] pl-4 pr-[0.55rem] shadow-[0_18px_55px_rgba(15,23,42,0.07)] backdrop-blur-[22px] transition-[border-color,background,box-shadow,transform] duration-200 max-[1080px]:grid-cols-[auto_1fr] max-[720px]:min-h-16 max-[720px]:w-full max-[720px]:py-[0.4rem] max-[720px]:pl-3 max-[720px]:pr-[0.45rem]"
    >
        <a
            href={currentLanguage === "es" ? "/es/" : "/"}
            class="inline-flex min-w-0 items-center gap-[0.65rem]"
            aria-label={`${siteConfig.name} home`}
        >
            <span
                class="relative inline-grid size-12 flex-none place-items-center"
                aria-hidden="true"
            >
                <img
                    src={siteConfig.assets.logo.light}
                    alt=""
                    class="brand-logo-mark brand-logo-light col-start-1 row-start-1 size-12 object-contain"
                    width="48"
                    height="48"
                />

                <img
                    src={siteConfig.assets.logo.dark}
                    alt=""
                    class="brand-logo-mark brand-logo-dark col-start-1 row-start-1 size-12 object-contain"
                    width="48"
                    height="48"
                />
            </span>

            <span class="grid gap-[0.1rem]">
                <strong
                    class="font-heading text-[1.05rem] text-[var(--color-heading)]"
                >
                    Victor Pazos, MD. PA.
                </strong>

                <small
                    class="text-[0.72rem] font-extrabold uppercase text-[var(--color-text-soft)]"
                >
                    Cardiology
                </small>
            </span>
        </a>

        <nav
            class="flex items-center justify-center gap-1 max-[1080px]:hidden"
            aria-label="Primary navigation"
        >
            {
                mainNavigation.map((item) => (
                    <a
                        href={item.href[currentLanguage]}
                        class="relative rounded-full px-[0.9rem] py-[0.72rem] text-sm font-extrabold text-[var(--color-text)] transition-[color,background] hover:bg-[color-mix(in_srgb,var(--color-secondary-soft)_46%,transparent)] hover:text-[var(--color-heading)]"
                    >
                        {item.label[currentLanguage]}
                    </a>
                ))
            }
        </nav>

        <div class="flex items-center justify-end gap-[0.45rem] max-[390px]:gap-[0.3rem]">
            <a
                href={alternatePath}
                class="grid size-11 place-items-center rounded-full border border-[var(--color-border)] bg-[color-mix(in_srgb,var(--color-surface)_86%,transparent)] text-[0.8rem] font-black text-[var(--color-heading)] shadow-[0_12px_32px_rgba(15,23,42,0.06)] transition-[transform,border-color,background] duration-200 hover:-translate-y-0.5 hover:border-[color-mix(in_srgb,var(--color-secondary)_42%,var(--color-border))] max-[720px]:size-[2.55rem]"
                aria-label={`Switch to ${
                    alternateLanguage === "es" ? "Spanish" : "English"
                }`}
            >
                {languageShortLabels[alternateLanguage]}
            </a>

            <ThemeToggle
                label={currentLanguage === "es" ? "Cambiar tema" : "Toggle theme"}
            />

            <a
                href={contactInfo.phone.href}
                class="btn btn-primary min-h-11 px-[1.1rem] text-[0.88rem] max-[720px]:hidden"
            >
                <span>{ctaNavigation.call.label[currentLanguage]}</span>
            </a>

            <button
                type="button"
                class="hidden size-11 place-items-center rounded-full border border-[var(--color-border)] bg-[color-mix(in_srgb,var(--color-surface)_86%,transparent)] text-[var(--color-heading)] transition-[transform,border-color,background] duration-200 hover:-translate-y-0.5 hover:border-[color-mix(in_srgb,var(--color-secondary)_42%,var(--color-border))] max-[1080px]:inline-grid max-[720px]:size-[2.55rem]"
                aria-label={mobileNavigationLabels.openMenu[currentLanguage]}
                aria-expanded="false"
                aria-controls="mobile-menu"
                data-menu-toggle
            >
                <MenuIcon class="menu-open-icon size-5" aria-hidden="true" />
                <XIcon class="menu-close-icon hidden size-5" aria-hidden="true" />
            </button>
        </div>
    </div>

    <div
        id="mobile-menu"
        class="fixed inset-0 z-[120] bg-[rgba(6,21,34,0.38)] p-4 backdrop-blur-[14px]"
        data-mobile-menu
        hidden
    >
        <div
            class="mobile-menu-panel flex max-h-[calc(100vh-2rem)] flex-col gap-4 overflow-y-auto rounded-[2rem] border border-[var(--color-border)] p-4 shadow-[var(--shadow-card)]"
        >
            <div class="flex items-center justify-between gap-4">
                <span
                    class="font-heading text-2xl font-extrabold text-[var(--color-heading)]"
                >
                    {mobileNavigationLabels.menu[currentLanguage]}
                </span>

                <button
                    type="button"
                    class="grid size-[2.6rem] place-items-center rounded-full border border-[var(--color-border)] bg-[color-mix(in_srgb,var(--color-surface-soft)_74%,transparent)] text-[var(--color-heading)] transition-[transform,border-color,background] duration-200 hover:-translate-y-0.5 hover:border-[color-mix(in_srgb,var(--color-secondary)_42%,var(--color-border))]"
                    aria-label={mobileNavigationLabels.closeMenu[currentLanguage]}
                    data-menu-close
                >
                    <XIcon class="size-5" aria-hidden="true" />
                </button>
            </div>

            <nav class="grid gap-[0.65rem]" aria-label="Mobile navigation">
                {
                    mainNavigation.map((item) => (
                        <a
                            href={item.href[currentLanguage]}
                            class="mobile-nav-link grid gap-1 rounded-[1.2rem] border border-[var(--color-border)] bg-[color-mix(in_srgb,var(--color-surface-soft)_54%,transparent)] p-4"
                            data-mobile-nav-link
                        >
                            <span class="font-black text-[var(--color-heading)]">
                                {item.label[currentLanguage]}
                            </span>

                            {item.description && (
                                <small class="text-[0.84rem] text-[var(--color-text-soft)]">
                                    {item.description[currentLanguage]}
                                </small>
                            )}
                        </a>
                    ))
                }
            </nav>

            <div class="grid gap-[0.65rem]">
                <a href={contactInfo.phone.href} class="btn btn-primary">
                    {ctaNavigation.call.label[currentLanguage]}
                </a>

                <a
                    href={ctaNavigation.appointment.href[currentLanguage]}
                    class="btn btn-secondary"
                >
                    {ctaNavigation.appointment.label[currentLanguage]}
                </a>
            </div>

            <div
                class="grid gap-[0.35rem] rounded-[1.25rem] border border-[var(--color-border)] bg-[color-mix(in_srgb,var(--color-secondary-soft)_34%,transparent)] p-4 text-sm text-[var(--color-text-soft)]"
            >
                <strong class="text-[var(--color-heading)]">
                    {contactInfo.practiceName}
                </strong>

                <span>{contactInfo.address.display}</span>

                <a
                    href={contactInfo.phone.href}
                    class="w-fit font-black text-[var(--color-secondary)]"
                >
                    {contactInfo.phone.label}
                </a>
            </div>
        </div>
    </div>
</header>

<script>
    function initSiteHeader() {
        const header = document.querySelector("[data-site-header]");
        const menu = document.querySelector("[data-mobile-menu]");
        const toggle = document.querySelector("[data-menu-toggle]");
        const closeButton = document.querySelector("[data-menu-close]");
        const mobileLinks = document.querySelectorAll("[data-mobile-nav-link]");

        if (!header || !menu || !toggle) return;

        if (toggle instanceof HTMLElement && toggle.dataset.menuInitialized === "true") {
            return;
        }

        if (toggle instanceof HTMLElement) {
            toggle.dataset.menuInitialized = "true";
        }

        const openIcon = toggle.querySelector(".menu-open-icon");
        const closeIcon = toggle.querySelector(".menu-close-icon");

        function openMenu() {
            menu.removeAttribute("hidden");
            toggle.setAttribute("aria-expanded", "true");
            document.documentElement.classList.add("menu-open");

            openIcon?.classList.add("hidden");
            closeIcon?.classList.remove("hidden");
        }

        function closeMenu() {
            menu.setAttribute("hidden", "");
            toggle.setAttribute("aria-expanded", "false");
            document.documentElement.classList.remove("menu-open");

            openIcon?.classList.remove("hidden");
            closeIcon?.classList.add("hidden");
        }

        function toggleMenu() {
            const isExpanded = toggle.getAttribute("aria-expanded") === "true";

            if (isExpanded) {
                closeMenu();
            } else {
                openMenu();
            }
        }

        function handleEscape(event) {
            if (event.key === "Escape") {
                closeMenu();
            }
        }

        function handleOverlayClick(event) {
            if (event.target === menu) {
                closeMenu();
            }
        }

        function handleScroll() {
            header.classList.toggle("is-scrolled", window.scrollY > 16);
        }

        toggle.addEventListener("click", toggleMenu);
        closeButton?.addEventListener("click", closeMenu);
        menu.addEventListener("click", handleOverlayClick);
        window.addEventListener("keydown", handleEscape);
        window.addEventListener("scroll", handleScroll, { passive: true });

        mobileLinks.forEach((link) => {
            link.addEventListener("click", closeMenu);
        });

        handleScroll();

        document.addEventListener(
            "astro:before-swap",
            () => {
                closeMenu();
                window.removeEventListener("keydown", handleEscape);
                window.removeEventListener("scroll", handleScroll);
            },
            { once: true },
        );
    }

    initSiteHeader();
    document.addEventListener("astro:page-load", initSiteHeader);
</script>

<style>
    .site-header {
        transition:
            padding 220ms var(--motion-smooth),
            background var(--theme-transition);
    }

    .site-header.is-scrolled {
        padding-block: 0.65rem;
    }

    .site-header.is-scrolled .header-shell {
        box-shadow: var(--shadow-card);
    }

    .brand-logo-mark {
        transition:
            opacity 180ms ease,
            transform 220ms var(--motion-smooth);
    }

    .brand-logo-light {
        opacity: 1;
        transform: scale(1);
    }

    .brand-logo-dark {
        opacity: 0;
        transform: scale(0.96);
    }

    :global(.dark) .brand-logo-light {
        opacity: 0;
        transform: scale(0.96);
    }

    :global(.dark) .brand-logo-dark {
        opacity: 1;
        transform: scale(1);
    }

    .mobile-menu-panel {
        background:
            radial-gradient(
                circle at top right,
                color-mix(in srgb, var(--color-secondary) 12%, transparent),
                transparent 16rem
            ),
            var(--color-surface);
    }

    :global(.menu-open) {
        overflow: hidden;
    }
</style>