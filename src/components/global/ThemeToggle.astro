---
import { Moon, Sun } from "@lucide/astro";

interface Props {
    label?: string;
}

const { label = "Toggle theme" } = Astro.props;
---

<button
    type="button"
    class="theme-toggle relative inline-grid size-11 place-items-center rounded-full border border-[var(--color-border)] bg-[color-mix(in_srgb,var(--color-surface)_86%,transparent)] text-[var(--color-heading)] shadow-[0_12px_32px_rgba(15,23,42,0.06)] backdrop-blur-2xl transition-[transform,border-color,background,color] duration-200 hover:-translate-y-0.5 hover:border-[color-mix(in_srgb,var(--color-secondary)_42%,var(--color-border))] max-[720px]:size-[2.55rem]"
    aria-label={label}
    aria-pressed="false"
    data-theme-toggle
>
    <span
        class="theme-toggle__icon theme-toggle__sun col-start-1 row-start-1 inline-grid place-items-center"
        aria-hidden="true"
    >
        <Sun size={18} strokeWidth={2} />
    </span>

    <span
        class="theme-toggle__icon theme-toggle__moon col-start-1 row-start-1 inline-grid place-items-center"
        aria-hidden="true"
    >
        <Moon size={18} strokeWidth={2} />
    </span>
</button>

<style>
    .theme-toggle {
        transition:
            transform 220ms var(--motion-smooth),
            border-color var(--theme-transition),
            background var(--theme-transition),
            color var(--theme-transition);
    }

    .theme-toggle__icon {
        transition:
            opacity 180ms ease,
            transform 220ms var(--motion-smooth);
    }

    .theme-toggle__moon {
        opacity: 0;
        transform: scale(0.8) rotate(-18deg);
    }

    .theme-toggle[data-theme-state="dark"] .theme-toggle__sun {
        opacity: 0;
        transform: scale(0.8) rotate(18deg);
    }

    .theme-toggle[data-theme-state="dark"] .theme-toggle__moon {
        opacity: 1;
        transform: scale(1) rotate(0deg);
    }
</style>