---
// src/components/global/MobileActionBar.astro

import { contactInfo } from "../../data/site/contact";
import { ctaNavigation } from "../../data/site/navigation";
import { getLanguageFromUrl } from "../../data/i18n/language";
import type { LanguageCode } from "../../data/site/siteConfig";

interface Props {
    language?: LanguageCode;
}

const { language } = Astro.props as Props;

const currentLanguage = language ?? getLanguageFromUrl(Astro.url.pathname);
---

<nav
    class="mobile-action-bar"
    aria-label={
        currentLanguage === "es"
        ? "Acciones rápidas de contacto"
        : "Quick contact actions"
    }
>
    <a href={contactInfo.phone.href} class="mobile-action-link primary">
        <span class="mobile-action-icon" aria-hidden="true">
        <svg
            viewBox="0 0 24 24"
            width="20"
            height="20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.1 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.33 1.77.62 2.61a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.47-1.19a2 2 0 0 1 2.11-.45c.84.29 1.71.5 2.61.62A2 2 0 0 1 22 16.92Z"
            />
        </svg>
        </span>

        <span>{ctaNavigation.call.shortLabel[currentLanguage]}</span>
    </a>

    <a href={contactInfo.email.href} class="mobile-action-link">
        <span class="mobile-action-icon" aria-hidden="true">
        <svg
            viewBox="0 0 24 24"
            width="20"
            height="20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-10 6L2 7" />
        </svg>
        </span>

        <span>{ctaNavigation.email.shortLabel[currentLanguage]}</span>
    </a>

    <a
        href={contactInfo.map.googleMapsUrl}
        class="mobile-action-link"
        target="_blank"
        rel="noopener noreferrer"
    >
        <span class="mobile-action-icon" aria-hidden="true">
        <svg
            viewBox="0 0 24 24"
            width="20"
            height="20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z" />
            <circle cx="12" cy="10" r="3" />
        </svg>
        </span>

        <span>{ctaNavigation.directions.shortLabel[currentLanguage]}</span>
    </a>

    <a
        href={ctaNavigation.appointment.href[currentLanguage]}
        class="mobile-action-link"
    >
        <span class="mobile-action-icon" aria-hidden="true">
        <svg
            viewBox="0 0 24 24"
            width="20"
            height="20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <path d="M8 2v4" />
            <path d="M16 2v4" />
            <rect width="18" height="18" x="3" y="4" rx="2" />
            <path d="M3 10h18" />
            <path d="M8 14h.01" />
            <path d="M12 14h.01" />
            <path d="M16 14h.01" />
            <path d="M8 18h.01" />
            <path d="M12 18h.01" />
        </svg>
        </span>

        <span>{ctaNavigation.appointment.shortLabel[currentLanguage]}</span>
    </a>
</nav>

<style>
    .mobile-action-bar {
        position: fixed;
        right: 0.75rem;
        bottom: 0.75rem;
        left: 0.75rem;
        z-index: 90;
        display: none;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.35rem;
        border: 1px solid color-mix(in srgb, var(--color-border) 86%, transparent);
        border-radius: 1.45rem;
        padding: 0.45rem;
        background:
        radial-gradient(
            circle at top left,
            color-mix(in srgb, var(--color-secondary) 12%, transparent),
            transparent 14rem
        ),
        color-mix(in srgb, var(--color-surface) 88%, transparent);
        box-shadow: 0 20px 60px rgba(15, 23, 42, 0.18);
        backdrop-filter: blur(24px);
    }

    .mobile-action-link {
        display: grid;
        place-items: center;
        gap: 0.28rem;
        min-height: 4rem;
        border-radius: 1.05rem;
        color: var(--color-text);
        font-size: 0.72rem;
        font-weight: 900;
        line-height: 1;
        text-align: center;
        transition:
        transform 220ms var(--motion-smooth),
        color var(--theme-transition),
        background var(--theme-transition);
    }

    .mobile-action-link:hover {
        transform: translateY(-2px);
        color: var(--color-heading);
        background: color-mix(in srgb, var(--color-secondary-soft) 44%, transparent);
    }

    .mobile-action-link.primary {
        color: #ffffff;
        background: linear-gradient(135deg, #0b2d4d, #0e7490);
        box-shadow: 0 12px 30px rgba(14, 116, 144, 0.25);
    }

    :global(.dark) .mobile-action-link.primary {
        color: #061522;
        background: linear-gradient(135deg, #8fd3e8, #22d3ee);
        box-shadow: 0 12px 30px rgba(34, 211, 238, 0.18);
    }

    .mobile-action-icon {
        display: inline-grid;
        place-items: center;
        width: 1.45rem;
        height: 1.45rem;
    }

    .mobile-action-link:not(.primary) .mobile-action-icon {
        color: var(--color-secondary);
    }

    @media (max-width: 720px) {
        .mobile-action-bar {
        display: grid;
        }
    }

    @media (max-width: 360px) {
        .mobile-action-bar {
        right: 0.5rem;
        bottom: 0.5rem;
        left: 0.5rem;
        border-radius: 1.25rem;
        }

        .mobile-action-link {
        min-height: 3.75rem;
        font-size: 0.68rem;
        }
    }
</style>