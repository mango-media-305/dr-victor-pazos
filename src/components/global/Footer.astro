---
import { siteConfig, type LanguageCode } from "../../data/site/siteConfig";
import { contactInfo } from "../../data/site/contact";
import { ctaNavigation, footerNavigation } from "../../data/site/navigation";
import { getLanguageFromUrl } from "../../data/i18n/language";

interface Props {
    language?: LanguageCode;
}

const { language } = Astro.props as Props;

const currentLanguage = language ?? getLanguageFromUrl(Astro.url.pathname);
const currentYear = new Date().getFullYear();

const logoLight = siteConfig.assets.logo.light;
const logoDark = siteConfig.assets.logo.dark;
---

<footer class="site-footer relative p-4 max-[680px]:p-3">
    <div
        class="footer-shell mx-auto w-[min(100%-1rem,1240px)] rounded-[2.25rem] border border-[var(--color-border)] p-[clamp(1.25rem,3vw,2rem)] shadow-[var(--shadow-soft)] backdrop-blur-[22px] max-[680px]:w-full max-[680px]:rounded-[1.75rem]"
    >
        <div
            class="grid grid-cols-[minmax(0,0.9fr)_minmax(0,1.4fr)] gap-[clamp(2rem,5vw,4rem)] max-[980px]:grid-cols-1"
        >
            <div class="grid content-start gap-5">
                <a
                    href={currentLanguage === "es" ? "/es/" : "/"}
                    class="inline-flex w-fit items-center gap-[0.85rem] max-[680px]:items-start"
                    aria-label={`${siteConfig.name} home`}
                >
                    <span
                        class="relative inline-grid size-16 flex-none place-items-center max-[680px]:size-[3.3rem]"
                        aria-hidden="true"
                    >
                        <img
                            src={logoLight}
                            alt=""
                            class="footer-logo footer-logo-light col-start-1 row-start-1 size-16 object-contain max-[680px]:size-[3.3rem]"
                            width="64"
                            height="64"
                            loading="lazy"
                        />

                        <img
                            src={logoDark}
                            alt=""
                            class="footer-logo footer-logo-dark col-start-1 row-start-1 size-16 object-contain max-[680px]:size-[3.3rem]"
                            width="64"
                            height="64"
                            loading="lazy"
                        />
                    </span>

                    <span class="grid gap-[0.15rem] leading-none">
                        <strong
                            class="font-heading text-[clamp(1.35rem,2vw,1.85rem)] tracking-[-0.04em] text-[var(--color-heading)]"
                        >
                            {siteConfig.name}
                        </strong>

                        <small
                            class="text-xs font-black uppercase tracking-[0.08em] text-[var(--color-secondary)]"
                        >
                            {siteConfig.doctor.specialtyExtended[currentLanguage]}
                        </small>
                    </span>
                </a>

                <p class="max-w-[34rem] text-base leading-[1.75] text-[var(--color-text-soft)]">
                    {siteConfig.description[currentLanguage]}
                </p>

                <div class="flex flex-wrap gap-3 max-[680px]:grid">
                    <a href={contactInfo.phone.href} class="btn btn-primary min-h-12 text-sm">
                        {ctaNavigation.call.label[currentLanguage]}
                    </a>

                    <a
                        href={ctaNavigation.appointment.href[currentLanguage]}
                        class="btn btn-secondary min-h-12 text-sm"
                    >
                        {ctaNavigation.appointment.label[currentLanguage]}
                    </a>
                </div>
            </div>

            <div
                class="grid grid-cols-3 gap-[clamp(1rem,3vw,2rem)] max-[980px]:grid-cols-2 max-[680px]:grid-cols-1"
            >
                <div class="grid content-start gap-4">
                    <h2
                        class="font-body text-[0.84rem] font-black uppercase tracking-[0.12em] text-[var(--color-heading)]"
                    >
                        {currentLanguage === "es" ? "Práctica" : "Practice"}
                    </h2>

                    <nav
                        class="grid gap-[0.65rem]"
                        aria-label={currentLanguage === "es" ? "Enlaces de práctica" : "Practice links"}
                    >
                        {
                            footerNavigation.practice.map((item) => (
                                <a
                                    href={item.href[currentLanguage]}
                                    class="w-fit text-[0.94rem] font-bold leading-[1.35] text-[var(--color-text-soft)] transition-[color,transform] duration-200 hover:translate-x-[3px] hover:text-[var(--color-secondary)]"
                                >
                                    {item.label[currentLanguage]}
                                </a>
                            ))
                        }
                    </nav>
                </div>

                <div class="grid content-start gap-4">
                    <h2
                        class="font-body text-[0.84rem] font-black uppercase tracking-[0.12em] text-[var(--color-heading)]"
                    >
                        {currentLanguage === "es" ? "Servicios" : "Services"}
                    </h2>

                    <nav
                        class="grid gap-[0.65rem]"
                        aria-label={currentLanguage === "es" ? "Enlaces de servicios" : "Service links"}
                    >
                        {
                            footerNavigation.services.map((item) => (
                                <a
                                    href={item.href[currentLanguage]}
                                    class="w-fit text-[0.94rem] font-bold leading-[1.35] text-[var(--color-text-soft)] transition-[color,transform] duration-200 hover:translate-x-[3px] hover:text-[var(--color-secondary)]"
                                >
                                    {item.label[currentLanguage]}
                                </a>
                            ))
                        }
                    </nav>
                </div>

                <div class="grid content-start gap-4">
                    <h2
                        class="font-body text-[0.84rem] font-black uppercase tracking-[0.12em] text-[var(--color-heading)]"
                    >
                        {currentLanguage === "es" ? "Contacto" : "Contact"}
                    </h2>

                    <address
                        class="grid gap-[0.3rem] text-[0.94rem] not-italic leading-[1.55] text-[var(--color-text-soft)]"
                    >
                        <span>{contactInfo.address.street}</span>
                        <span>{contactInfo.address.suite}</span>
                        <span>
                            {contactInfo.address.city}, {contactInfo.address.state}{" "}
                            {contactInfo.address.zip}
                        </span>
                    </address>

                    <div class="grid gap-[0.55rem]">
                        <a
                            href={contactInfo.phone.href}
                            class="w-fit text-[0.94rem] font-bold leading-[1.35] text-[var(--color-text-soft)] transition-[color,transform] duration-200 hover:translate-x-[3px] hover:text-[var(--color-secondary)]"
                        >
                            {contactInfo.phone.label}
                        </a>

                        <a
                            href={contactInfo.email.href}
                            class="w-fit text-[0.94rem] font-bold leading-[1.35] text-[var(--color-text-soft)] transition-[color,transform] duration-200 hover:translate-x-[3px] hover:text-[var(--color-secondary)]"
                        >
                            {contactInfo.email.label}
                        </a>

                        <a
                            href={contactInfo.map.googleMapsUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="w-fit text-[0.94rem] font-bold leading-[1.35] text-[var(--color-text-soft)] transition-[color,transform] duration-200 hover:translate-x-[3px] hover:text-[var(--color-secondary)]"
                        >
                            {contactInfo.map.directionsLabel[currentLanguage]}
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div
            class="mt-[clamp(2rem,5vw,3.5rem)] grid gap-[0.85rem] rounded-3xl border border-[var(--color-border)] bg-[color-mix(in_srgb,var(--color-surface-soft)_52%,transparent)] p-[clamp(1rem,2vw,1.25rem)]"
        >
            <span
                class="text-xs font-black uppercase tracking-[0.14em] text-[var(--color-secondary)]"
            >
                {currentLanguage === "es" ? "Áreas de servicio" : "Service Areas"}
            </span>

            <p class="max-w-[56rem] leading-[1.7] text-[var(--color-text-soft)]">
                {
                    currentLanguage === "es"
                        ? "Atención cardiológica para pacientes en Hialeah, Miami y comunidades cercanas de Miami-Dade County."
                        : "Cardiology care for patients in Hialeah, Miami, and nearby Miami-Dade County communities."
                }
            </p>

            <div
                class="flex flex-wrap gap-[0.55rem]"
                aria-label={currentLanguage === "es" ? "Áreas cercanas" : "Nearby areas"}
            >
                {
                    contactInfo.serviceArea.nearbyAreas.map((area) => (
                        <span class="rounded-full border border-[var(--color-border)] bg-[color-mix(in_srgb,var(--color-surface)_74%,transparent)] px-[0.7rem] py-[0.45rem] text-[0.83rem] font-extrabold text-[var(--color-text)]">
                            {area}
                        </span>
                    ))
                }
            </div>
        </div>

        <div class="mt-4 rounded-[1.2rem] p-4">
            <p class="text-[0.5rem] leading-[1.65] text-[var(--color-text-soft)]">
                {
                    currentLanguage === "es"
                        ? "Este sitio web proporciona información general y no reemplaza una consulta médica profesional. Si tiene una emergencia médica, llame al 911 de inmediato."
                        : "This website provides general information and does not replace professional medical advice. If you are experiencing a medical emergency, call 911 immediately."
                }
            </p>
        </div>

        <div
            class="mt-5 flex items-center justify-between gap-4 border-t border-[var(--color-border)] pt-5 text-[0.88rem] text-[var(--color-text-soft)] max-[680px]:grid max-[680px]:gap-[0.9rem]"
        >
            <p>
                © {currentYear} {siteConfig.name}.{" "}
                {currentLanguage === "es"
                    ? "Todos los derechos reservados."
                    : "All rights reserved."}
            </p>

            <nav
                class="flex flex-wrap justify-end gap-[0.9rem] max-[680px]:justify-start"
                aria-label={currentLanguage === "es" ? "Enlaces legales" : "Legal links"}
            >
                {
                    footerNavigation.legal.map((item) => (
                        <a
                            href={item.href[currentLanguage]}
                            class="font-extrabold text-[var(--color-text-soft)] hover:text-[var(--color-secondary)]"
                        >
                            {item.label[currentLanguage]}
                        </a>
                    ))
                }
            </nav>
        </div>
    </div>
</footer>

<style>
    .footer-shell {
        background:
            radial-gradient(
                circle at top left,
                color-mix(in srgb, var(--color-secondary) 14%, transparent),
                transparent 22rem
            ),
            radial-gradient(
                circle at bottom right,
                color-mix(in srgb, var(--color-accent) 12%, transparent),
                transparent 20rem
            ),
            color-mix(in srgb, var(--color-surface) 86%, transparent);
    }

    .footer-logo {
        transition:
            opacity 180ms ease,
            transform 220ms var(--motion-smooth);
    }

    .footer-logo-light {
        opacity: 1;
        transform: scale(1);
    }

    .footer-logo-dark {
        opacity: 0;
        transform: scale(0.96);
    }

    :global(.dark) .footer-logo-light {
        opacity: 0;
        transform: scale(0.96);
    }

    :global(.dark) .footer-logo-dark {
        opacity: 1;
        transform: scale(1);
    }

    @media (max-width: 680px) {
        .site-footer {
            padding-bottom: 5.5rem;
        }
    }
</style>