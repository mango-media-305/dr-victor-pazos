---
const heroBackgroundImages = [
    "/images/home/hero/cardiology-office.webp",
    "/images/home/hero/heart-care-miami.webp",
    "/images/home/hero/doctor-consultation.webp",
    "/images/home/hero/medical-technology.webp",
];

import { contactInfo } from "../../data/site/contact";
import { ctaNavigation } from "../../data/site/navigation";
import { getLanguageFromUrl } from "../../data/i18n/language";
import type { LanguageCode } from "../../data/site/siteConfig";

import AnatomicHeart from "../svg/anatomic-heart.astro";

interface Props {
    language?: LanguageCode;
}

const { language } = Astro.props as Props;

const currentLanguage = language ?? getLanguageFromUrl(Astro.url.pathname);

const content = {
    en: {
        eyebrow: "Interventional Cardiology in South Florida",
        title: "Experienced Heart Care for Miami-Dade.",
        highlighted: "Led by Victor Pazos, MD.",
        description:
            "Victor Pazos, MD. PA. provides cardiology and interventional cardiology care for patients in Hialeah, Miami, and nearby Miami-Dade communities.",
        call: ctaNavigation.call.label.en,
        appointment: ctaNavigation.appointment.label.en,
        statOne: "35+",
        statOneLabel: "Years of medical experience",
        statTwo: "Miami-Dade",
        statTwoLabel: "Serving local heart patients",
        cardTitle: "Victor Pazos, MD. PA.",
        cardSubtitle: "Cardiology Specialist",
        pulseLabel: "Live heart rhythm visual",
        locationLabel: "Office Location",
    },
    es: {
        eyebrow: "Cardiología intervencionista en el sur de Florida",
        title: "Cuidado del corazón para Miami-Dade.",
        highlighted: "Dirigido por Victor Pazos, MD.",
        description:
            "Victor Pazos, MD. PA. ofrece atención cardiológica y cardiología intervencionista para pacientes en Hialeah, Miami y comunidades cercanas de Miami-Dade.",
        call: ctaNavigation.call.label.es,
        appointment: ctaNavigation.appointment.label.es,
        statOne: "35+",
        statOneLabel: "Años de experiencia médica",
        statTwo: "Miami-Dade",
        statTwoLabel: "Atendiendo pacientes locales",
        cardTitle: "Victor Pazos, MD. PA.",
        cardSubtitle: "Especialista en cardiología",
        pulseLabel: "Visual de ritmo cardíaco",
        locationLabel: "Ubicación de la oficina",
    },
};

const t = content[currentLanguage];
---

<section class="home-hero section-padding-lg medical-grid-bg -mt-25">
    <div class="hero-bg-slider" aria-hidden="true">
        {
            heroBackgroundImages.map((image, index) => (
                <div
                    class="hero-bg-slide"
                    style={`--slide-delay: ${index * 6}s;`}
                >
                    <img
                        src={image}
                        alt=""
                        class="hero-bg-image"
                        loading={index === 0 ? "eager" : "lazy"}
                        decoding="async"
                    />
                </div>
            ))
        }
    </div>

    <div class="hero-bg-overlay opacity-75!" aria-hidden="true"></div>

    <div class="hero-orb hero-orb-one"></div>
    <div class="hero-orb hero-orb-two"></div>
    <div class="hero-orb hero-orb-three"></div>

    <div class="site-container hero-container">
        <div class="hero-copy">
            <span class="eyebrow-pill animate-blur-in">
                <span class="hero-eyebrow-dot" aria-hidden="true"></span>
                {t.eyebrow}
            </span>

            <h1 class="hero-title animate-fade-up animation-delay-100">
                {t.title}
                <span>{t.highlighted}</span>
            </h1>

            <p class="hero-description animate-fade-up animation-delay-200">
                {t.description}
            </p>

            <div class="hero-actions animate-fade-up animation-delay-300">
                <a href={contactInfo.phone.href} class="btn btn-primary hero-call">
                    <span class="btn-pulse" aria-hidden="true"></span>
                    {t.call}
                </a>

                <a
                    href={ctaNavigation.appointment.href[currentLanguage]}
                    class="btn btn-secondary"
                >
                    {t.appointment}
                </a>
            </div>
        </div>

        <div class="hero-visual animate-scale-in animation-delay-200">
            <div class="hero-heart-stage" aria-label={t.pulseLabel}>
                <div class="heart-halo"></div>

                <div class="hero-heart-card">
                    <div class="heart-grid"></div>

                    <div
                        class="hero-heart-illustration-shell opacity-45"
                        aria-hidden="true"
                    >
                        <AnatomicHeart class="hero-anatomic-heart" />
                    </div>

                    <svg
                        class="heartbeat-line"
                        viewBox="0 0 720 180"
                        fill="none"
                        aria-hidden="true"
                    >
                        <path
                            class="heartbeat-shadow"
                            d="M0 92H150L178 92L205 92L230 32L270 150L305 92H360L385 92L410 62L440 122L470 92H720"
                        ></path>
                        <path
                            class="heartbeat-path"
                            d="M0 92H150L178 92L205 92L230 32L270 150L305 92H360L385 92L410 62L440 122L470 92H720"
                        ></path>
                    </svg>

                    <div class="heart-beat-ring ring-one"></div>
                    <div class="heart-beat-ring ring-two"></div>
                </div>

                <div class="hero-doctor-card glass-panel">
                    <span class="doctor-card-kicker">
                        {t.cardSubtitle}
                    </span>

                    <strong>{t.cardTitle}</strong>

                    <div class="doctor-card-line"></div>
                </div>

                <div class="hero-stat-card hero-stat-left medical-card">
                    <strong>{t.statOne}</strong>
                    <span>{t.statOneLabel}</span>
                </div>

                <div class="hero-stat-card hero-stat-right medical-card">
                    <strong>{t.statTwo}</strong>
                    <span>{t.statTwoLabel}</span>
                </div>

                <div class="hero-mini-card hero-location-card">
                    <span>{t.locationLabel}</span>
                    <strong>Hialeah, FL</strong>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .home-hero {
        position: relative;
        overflow: hidden;
        isolation: isolate;
    }

    .hero-bg-slider {
        position: absolute;
        inset: 0;
        z-index: -4;
        overflow: hidden;
        pointer-events: none;
    }

    .hero-bg-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        animation: hero-bg-fade 24s ease-in-out infinite;
        animation-delay: var(--slide-delay);
        will-change: opacity;
    }

    .hero-bg-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        max-width: none;
        object-fit: cover;
        object-position: center center;
        transform-origin: center center;
        transform: scale(1.05);
        filter: saturate(0.9) contrast(1.05);
        animation: hero-bg-ken-burns-image 24s ease-in-out infinite;
        animation-delay: var(--slide-delay);
        will-change: transform;
    }

    .hero-bg-slide:nth-child(2) .hero-bg-image,
    .hero-bg-slide:nth-child(3) .hero-bg-image,
    .hero-bg-slide:nth-child(4) .hero-bg-image {
        object-position: center center;
        transform-origin: center center;
    }

    .hero-bg-overlay {
        position: absolute;
        inset: 0;
        z-index: -3;
        background:
            linear-gradient(
                90deg,
                var(--color-bg) 0%,
                color-mix(in srgb, var(--color-bg) 88%, transparent) 34%,
                color-mix(in srgb, var(--color-bg) 66%, transparent) 62%,
                color-mix(in srgb, var(--color-bg) 78%, transparent) 100%
            ),
            radial-gradient(
                circle at 68% 48%,
                color-mix(in srgb, var(--color-secondary) 18%, transparent),
                transparent 30rem
            ),
            radial-gradient(
                circle at 20% 20%,
                color-mix(in srgb, var(--color-accent) 12%, transparent),
                transparent 24rem
            );
        pointer-events: none;
    }

    :global(.dark) .hero-bg-image {
        filter: saturate(0.85) contrast(1.05) brightness(0.75);
    }

    :global(.dark) .hero-bg-overlay {
        background:
            linear-gradient(
                90deg,
                var(--color-bg) 0%,
                color-mix(in srgb, var(--color-bg) 88%, transparent) 36%,
                color-mix(in srgb, var(--color-bg) 70%, transparent) 64%,
                color-mix(in srgb, var(--color-bg) 84%, transparent) 100%
            ),
            radial-gradient(
                circle at 68% 48%,
                color-mix(in srgb, var(--color-secondary) 16%, transparent),
                transparent 30rem
            ),
            radial-gradient(
                circle at 20% 20%,
                color-mix(in srgb, var(--color-accent) 10%, transparent),
                transparent 24rem
            );
    }

    .hero-container {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
        align-items: center;
        gap: clamp(2.5rem, 5vw, 4.5rem);
    }

    .hero-copy {
        display: grid;
        align-content: center;
        justify-items: start;
    }

    .hero-eyebrow-dot {
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 999px;
        background: var(--color-heart);
        box-shadow: 0 0 0 0 rgba(185, 28, 28, 0.4);
        animation: hero-dot-pulse 1.55s ease-in-out infinite;
    }

    .hero-title {
        max-width: 820px;
        margin-top: 1.35rem;
        color: var(--color-heading);
        font-size: clamp(3.15rem, 15vw, 4.8rem);
        overflow: visible;
    }

    .hero-title span {
        display: inline-block;
        margin-top: 0.2rem;
        padding-bottom: 0.12em;
        line-height: 1.12;
        color: transparent;
        background: linear-gradient(
            135deg,
            var(--color-primary-dark),
            var(--color-secondary),
            var(--color-accent)
        );
        background-clip: text;
        -webkit-background-clip: text;
        overflow: visible;
    }

    :global(.dark) .hero-title span {
        background: linear-gradient(
            135deg,
            var(--color-heading),
            var(--color-secondary),
            var(--color-accent)
        );
        background-clip: text;
        -webkit-background-clip: text;
    }

    .hero-description {
        max-width: 660px;
        margin-top: 1.35rem;
        color: var(--color-text-soft);
        font-size: clamp(1.05rem, 1.5vw, 1.25rem);
        line-height: 1.85;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-top: 2rem;
    }

    .hero-call {
        position: relative;
        overflow: hidden;
    }

    .btn-pulse {
        width: 0.65rem;
        height: 0.65rem;
        border-radius: 999px;
        background: currentColor;
        opacity: 0.9;
        box-shadow: 0 0 0 0 currentColor;
        animation: button-heartbeat 1.5s ease-in-out infinite;
    }

    .hero-visual {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 620px;
        width: 100%;
    }

    .hero-heart-stage {
        position: relative;
        display: grid;
        place-items: center;
        width: min(100%, 620px);
        min-height: 620px;
        margin-inline: auto;
    }

    .hero-heart-card {
        position: relative;
        display: grid;
        place-items: center;
        width: min(100%, 500px);
        aspect-ratio: 1;
        overflow: hidden;
        border: 1px solid
            color-mix(in srgb, var(--color-secondary) 32%, var(--color-border));
        border-radius: 42% 58% 52% 48% / 45% 43% 57% 55%;
        background:
            radial-gradient(
                circle at 50% 42%,
                color-mix(in srgb, var(--color-heart) 14%, transparent),
                transparent 11rem
            ),
            radial-gradient(
                circle at 52% 48%,
                color-mix(in srgb, var(--color-secondary) 24%, transparent),
                transparent 17rem
            ),
            linear-gradient(
                145deg,
                color-mix(in srgb, var(--color-surface) 86%, transparent),
                color-mix(in srgb, var(--color-surface-soft) 72%, transparent)
            );
        box-shadow:
            0 36px 90px rgba(15, 23, 42, 0.14),
            inset 0 1px 0 rgba(255, 255, 255, 0.32);
        backdrop-filter: blur(24px);
        animation:
            organic-heart-morph 9s ease-in-out infinite,
            heart-soft-beat 1.55s ease-in-out infinite;
    }

    :global(.dark) .hero-heart-card {
        box-shadow:
            0 36px 110px rgba(0, 0, 0, 0.36),
            inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }

    .heart-grid {
        position: absolute;
        inset: 0;
        opacity: 0.52;
        background-image:
            linear-gradient(
                to right,
                color-mix(in srgb, var(--color-border) 72%, transparent) 1px,
                transparent 1px
            ),
            linear-gradient(
                to bottom,
                color-mix(in srgb, var(--color-border) 72%, transparent) 1px,
                transparent 1px
            );
        background-size: 34px 34px;
        mask-image: radial-gradient(circle at center, black, transparent 70%);
    }

    .heart-halo {
        position: absolute;
        width: min(90vw, 640px);
        aspect-ratio: 1;
        border-radius: 999px;
        background:
            radial-gradient(
                circle,
                color-mix(in srgb, var(--color-heart) 18%, transparent),
                transparent 46%
            ),
            radial-gradient(
                circle,
                color-mix(in srgb, var(--color-secondary) 20%, transparent),
                transparent 62%
            ),
            radial-gradient(
                circle,
                color-mix(in srgb, var(--color-accent) 12%, transparent),
                transparent 76%
            );
        filter: blur(8px);
        opacity: 0.8;
        animation: halo-heartbeat 1.55s ease-in-out infinite;
    }

    .hero-heart-illustration-shell {
        position: absolute;
        z-index: 0;
        display: grid;
        place-items: center;
        width: 960px;
        aspect-ratio: 1;
        border-radius: 999px;
        color: var(--color-heart);
        filter:
            drop-shadow(0 24px 40px rgba(15, 23, 42, 0.16))
            drop-shadow(
                0 0 28px color-mix(in srgb, var(--color-heart) 18%, transparent)
            );
        animation: anatomic-heartbeat 1.55s ease-in-out infinite;
    }

    :global(.hero-anatomic-heart) {
        display: block;
        width: 128%;
        height: 128%;
        overflow: visible;
        color: var(--color-heart);
        fill: currentColor;
        transform-origin: center;
        animation: anatomic-heart-inner-beat 1.55s ease-in-out infinite;
    }

    :global(.hero-anatomic-heart .heart-main-layer),
    :global(.hero-anatomic-heart .heart-main-layer path) {
        fill: url("#heartBrandGradient");
        stroke: none;
    }

    :global(.hero-anatomic-heart .heart-glow-layer),
    :global(.hero-anatomic-heart .heart-glow-layer ellipse) {
        fill: url("#heartBrandGlow");
    }

    .heartbeat-line {
        position: absolute;
        z-index: 8;
        left: 50%;
        top: 50%;
        width: 128%;
        transform: translate(-50%, -50%);
        filter: drop-shadow(
            0 0 14px color-mix(in srgb, var(--color-accent) 58%, transparent)
        );
        pointer-events: none;
    }

    .heartbeat-shadow,
    .heartbeat-path {
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .heartbeat-shadow {
        stroke: color-mix(in srgb, var(--color-accent) 18%, transparent);
        stroke-width: 13;
    }

    .heartbeat-path {
        stroke: var(--color-accent);
        stroke-width: 5;
        stroke-dasharray: 930;
        stroke-dashoffset: 930;
        animation: draw-heartbeat 3.25s ease-in-out infinite;
    }

    .heart-beat-ring {
        position: absolute;
        inset: 9%;
        border: 1px solid
            color-mix(in srgb, var(--color-secondary) 35%, transparent);
        border-radius: inherit;
        opacity: 0;
        animation: heartbeat-ring 1.55s ease-out infinite;
    }

    .ring-two {
        animation-delay: 0.3s;
    }

    .hero-doctor-card {
        position: absolute;
        z-index: 9;
        right: 20%;
        bottom: 2.75rem;
        display: grid;
        gap: 0.5rem;
        padding: 1.2rem;
        transform: translateX(50%);
    }

    .doctor-card-kicker {
        color: var(--color-secondary);
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .hero-doctor-card strong {
        color: var(--color-heading);
        font-family: var(--font-heading);
        font-size: clamp(1.45rem, 2vw, 2rem);
        line-height: 1;
        letter-spacing: -0.04em;
    }

    .doctor-card-line {
        width: 100%;
        height: 2px;
        margin-block: 0.25rem;
        border-radius: 999px;
        background: linear-gradient(
            90deg,
            var(--color-secondary),
            var(--color-heart),
            var(--color-accent)
        );
    }

    .hero-stat-card {
        position: absolute;
        z-index: 7;
        display: grid;
        gap: 0.25rem;
        padding: 1rem;
    }

    .hero-stat-card strong {
        color: var(--color-heading);
        font-family: var(--font-heading);
        font-size: 2.25rem;
        line-height: 1;
    }

    .hero-stat-card span {
        color: var(--color-text-soft);
        font-size: 0.82rem;
        font-weight: 800;
        line-height: 1.35;
    }

    .hero-stat-left {
        top: 4.25rem;
        left: 1.25rem;
        animation: float-soft 6.5s ease-in-out infinite;
    }

    .hero-stat-right {
        top: 6.25rem;
        right: 0.25rem;
        animation: float-soft 7.4s ease-in-out infinite reverse;
    }

    .hero-mini-card {
        position: absolute;
        z-index: 7;
        display: grid;
        gap: 0.15rem;
        border: 1px solid var(--color-border);
        border-radius: 1.2rem;
        padding: 0.85rem 1rem;
        background: color-mix(in srgb, var(--color-surface) 82%, transparent);
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(18px);
    }

    .hero-mini-card span {
        color: var(--color-text-soft);
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .hero-mini-card strong {
        color: var(--color-heading);
        font-size: 0.95rem;
        font-weight: 900;
    }

    .hero-location-card {
        left: 2rem;
        bottom: 6.25rem;
    }

    .hero-orb {
        position: absolute;
        z-index: 0;
        border-radius: 999px;
        filter: blur(60px);
        opacity: 0.52;
        pointer-events: none;
    }

    .hero-orb-one {
        top: 8%;
        left: 4%;
        width: 18rem;
        height: 18rem;
        background: color-mix(in srgb, var(--color-secondary) 35%, transparent);
    }

    .hero-orb-two {
        right: 8%;
        top: 16%;
        width: 24rem;
        height: 24rem;
        background: color-mix(in srgb, var(--color-accent) 28%, transparent);
    }

    .hero-orb-three {
        right: 28%;
        bottom: 10%;
        width: 18rem;
        height: 18rem;
        background: color-mix(in srgb, var(--color-heart) 16%, transparent);
    }

    @keyframes hero-bg-fade {
        0% {
            opacity: 0;
        }

        6% {
            opacity: 0.22;
        }

        25% {
            opacity: 0.22;
        }

        31% {
            opacity: 0;
        }

        100% {
            opacity: 0;
        }
    }

    @keyframes hero-bg-ken-burns-image {
        0% {
            transform: scale(1.05);
        }

        25% {
            transform: scale(1.16);
        }

        31% {
            transform: scale(1.2);
        }

        100% {
            transform: scale(1.2);
        }
    }

    @keyframes draw-heartbeat {
        0% {
            stroke-dashoffset: 930;
            opacity: 0;
        }

        12% {
            opacity: 1;
        }

        48% {
            stroke-dashoffset: 0;
            opacity: 1;
        }

        70% {
            stroke-dashoffset: 0;
            opacity: 0.9;
        }

        100% {
            stroke-dashoffset: -930;
            opacity: 0;
        }
    }

    @keyframes heart-soft-beat {
        0%,
        100% {
            transform: scale(1);
        }

        10% {
            transform: scale(1.018);
        }

        18% {
            transform: scale(1);
        }

        28% {
            transform: scale(1.012);
        }

        36% {
            transform: scale(1);
        }
    }

    @keyframes anatomic-heartbeat {
        0%,
        100% {
            transform: scale(1);
            filter:
                drop-shadow(0 24px 40px rgba(15, 23, 42, 0.16))
                drop-shadow(
                    0 0 22px color-mix(in srgb, var(--color-heart) 16%, transparent)
                );
        }

        10% {
            transform: scale(1.055);
            filter:
                drop-shadow(0 28px 46px rgba(15, 23, 42, 0.2))
                drop-shadow(
                    0 0 34px color-mix(in srgb, var(--color-heart) 28%, transparent)
                );
        }

        18% {
            transform: scale(1);
        }

        28% {
            transform: scale(1.035);
        }

        36% {
            transform: scale(1);
        }
    }

    @keyframes anatomic-heart-inner-beat {
        0%,
        100% {
            transform: scale(1) rotate(-1deg);
        }

        10% {
            transform: scale(1.045) rotate(1deg);
        }

        18% {
            transform: scale(1) rotate(-1deg);
        }

        28% {
            transform: scale(1.025) rotate(0.5deg);
        }

        36% {
            transform: scale(1) rotate(-1deg);
        }
    }

    @keyframes halo-heartbeat {
        0%,
        100% {
            opacity: 0.55;
            transform: scale(0.96);
        }

        10% {
            opacity: 0.92;
            transform: scale(1.04);
        }

        18% {
            opacity: 0.62;
            transform: scale(0.98);
        }

        28% {
            opacity: 0.82;
            transform: scale(1.025);
        }

        36% {
            opacity: 0.58;
            transform: scale(0.98);
        }
    }

    @keyframes heartbeat-ring {
        0% {
            opacity: 0.4;
            transform: scale(0.9);
        }

        70% {
            opacity: 0;
            transform: scale(1.12);
        }

        100% {
            opacity: 0;
            transform: scale(1.12);
        }
    }

    @keyframes organic-heart-morph {
        0%,
        100% {
            border-radius: 42% 58% 52% 48% / 45% 43% 57% 55%;
        }

        35% {
            border-radius: 50% 50% 45% 55% / 47% 55% 45% 53%;
        }

        70% {
            border-radius: 46% 54% 58% 42% / 55% 45% 55% 45%;
        }
    }

    @keyframes hero-dot-pulse {
        0%,
        100% {
            box-shadow: 0 0 0 0
                color-mix(in srgb, var(--color-heart) 44%, transparent);
            transform: scale(1);
        }

        50% {
            box-shadow: 0 0 0 8px
                color-mix(in srgb, var(--color-heart) 0%, transparent);
            transform: scale(1.16);
        }
    }

    @keyframes button-heartbeat {
        0%,
        100% {
            transform: scale(1);
            opacity: 0.9;
        }

        18% {
            transform: scale(1.45);
            opacity: 0.65;
        }

        32% {
            transform: scale(1);
            opacity: 0.9;
        }
    }

    @media (max-width: 1080px) {
