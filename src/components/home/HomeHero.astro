---
// src/components/home/HomeHero.astro

import { siteConfig, type LanguageCode } from "../../data/site/siteConfig";
import { contactInfo } from "../../data/site/contact";
import { ctaNavigation } from "../../data/site/navigation";
import { getLanguageFromUrl } from "../../data/i18n/language";

interface Props {
    language?: LanguageCode;
}

const { language } = Astro.props as Props;

const currentLanguage = language ?? getLanguageFromUrl(Astro.url.pathname);

const content = {
    en: {
        eyebrow: "Interventional Cardiology in Hialeah, FL",
        title: "Experienced Heart Care for Miami-Dade.",
        highlighted: "Led by Victor Pazos, MD.",
        description:
        "Victor Pazos, MD. PA. provides cardiology and interventional cardiology care for patients in Hialeah, Miami, and nearby Miami-Dade communities.",
        call: ctaNavigation.call.label.en,
        appointment: ctaNavigation.appointment.label.en,
        trust: [
        "Cardiology & Interventional Cardiology",
        "English & Spanish",
        "Hialeah Office",
        ],
        statOne: "35+",
        statOneLabel: "Years of medical experience",
        statTwo: "Miami-Dade",
        statTwoLabel: "Serving local heart patients",
        cardTitle: "Victor Pazos, MD. PA.",
        cardSubtitle: "Cardiology Specialist",
        pulseLabel: "Live heart rhythm visual",
        locationLabel: "Office Location",
        phoneLabel: "Phone-first appointments",
    },
    es: {
        eyebrow: "Cardiología intervencionista en Hialeah, FL",
        title: "Cuidado del corazón para Miami-Dade.",
        highlighted: "Dirigido por Victor Pazos, MD.",
        description:
        "Victor Pazos, MD. PA. ofrece atención cardiológica y cardiología intervencionista para pacientes en Hialeah, Miami y comunidades cercanas de Miami-Dade.",
        call: ctaNavigation.call.label.es,
        appointment: ctaNavigation.appointment.label.es,
        trust: [
        "Cardiología y cardiología intervencionista",
        "Inglés y español",
        "Oficina en Hialeah",
        ],
        statOne: "35+",
        statOneLabel: "Años de experiencia médica",
        statTwo: "Miami-Dade",
        statTwoLabel: "Atendiendo pacientes locales",
        cardTitle: "Victor Pazos, MD. PA.",
        cardSubtitle: "Especialista en cardiología",
        pulseLabel: "Visual de ritmo cardíaco",
        locationLabel: "Ubicación de la oficina",
        phoneLabel: "Citas por teléfono primero",
    },
};

const t = content[currentLanguage];
---

<section class="home-hero medical-grid-bg">
    <div class="hero-orb hero-orb-one"></div>
    <div class="hero-orb hero-orb-two"></div>
    <div class="hero-orb hero-orb-three"></div>

    <div class="container-shell hero-container">
        <div class="hero-copy">
        <span class="eyebrow-pill animate-blur-in">
            <span class="hero-eyebrow-dot" aria-hidden="true"></span>
            {t.eyebrow}
        </span>

        <h1 class="hero-title animate-fade-up animation-delay-100">
            {t.title}
            <span>{t.highlighted}</span>
        </h1>

        <p class="hero-description animate-fade-up animation-delay-200">
            {t.description}
        </p>

        <div class="hero-actions animate-fade-up animation-delay-300">
            <a href={contactInfo.phone.href} class="btn btn-primary hero-call">
            <span class="btn-pulse" aria-hidden="true"></span>
            {t.call}
            </a>

            <a
            href={ctaNavigation.appointment.href[currentLanguage]}
            class="btn btn-secondary"
            >
            {t.appointment}
            </a>
        </div>

        <div class="hero-trust animate-fade-up animation-delay-500">
            {t.trust.map((item) => <span class="trust-badge">{item}</span>)}
        </div>
        </div>

        <div class="hero-visual animate-scale-in animation-delay-200">
        <div class="hero-heart-stage" aria-label={t.pulseLabel}>
            <div class="heart-halo"></div>

            <div class="hero-heart-card">
            <div class="heart-grid"></div>

            <div class="hero-logo-shell">
                <img
                src={siteConfig.assets.logo.light}
                alt=""
                class="hero-logo hero-logo-light"
                width="112"
                height="112"
                />

                <img
                src={siteConfig.assets.logo.dark}
                alt=""
                class="hero-logo hero-logo-dark"
                width="112"
                height="112"
                />
            </div>

            <svg
                class="heartbeat-line"
                viewBox="0 0 720 180"
                fill="none"
                aria-hidden="true"
            >
                <path
                class="heartbeat-shadow"
                d="M0 92H150L178 92L205 92L230 32L270 150L305 92H360L385 92L410 62L440 122L470 92H720"
                />
                <path
                class="heartbeat-path"
                d="M0 92H150L178 92L205 92L230 32L270 150L305 92H360L385 92L410 62L440 122L470 92H720"
                />
            </svg>

            <div class="heart-beat-ring ring-one"></div>
            <div class="heart-beat-ring ring-two"></div>
            </div>

            <div class="hero-doctor-card glass-panel">
            <span class="doctor-card-kicker">
                {t.cardSubtitle}
            </span>

            <strong>{t.cardTitle}</strong>

            <div class="doctor-card-line"></div>

            <div class="doctor-card-meta">
                <span>{contactInfo.languages.display[currentLanguage]}</span>
                <span>{contactInfo.serviceArea.primaryCity}, FL</span>
            </div>
            </div>

            <div class="hero-stat-card hero-stat-left medical-card">
            <strong>{t.statOne}</strong>
            <span>{t.statOneLabel}</span>
            </div>

            <div class="hero-stat-card hero-stat-right medical-card">
            <strong>{t.statTwo}</strong>
            <span>{t.statTwoLabel}</span>
            </div>

            <div class="hero-mini-card hero-location-card">
            <span>{t.locationLabel}</span>
            <strong>Hialeah, FL</strong>
            </div>

            <div class="hero-mini-card hero-phone-card">
            <span>{t.phoneLabel}</span>
            <strong>{contactInfo.phone.label}</strong>
            </div>
        </div>
        </div>
    </div>
</section>

<style>
    .home-hero {
        position: relative;
        overflow: hidden;
        padding: clamp(4.5rem, 7vw, 7rem) 1rem clamp(5rem, 8vw, 8rem);
        isolation: isolate;
    }

    .hero-container {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
        align-items: center;
        gap: clamp(2.5rem, 5vw, 4.5rem);
    }

    .hero-copy {
        display: grid;
        align-content: center;
        justify-items: start;
    }

    .hero-eyebrow-dot {
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 999px;
        background: var(--color-heart);
        box-shadow: 0 0 0 0 rgba(185, 28, 28, 0.4);
        animation: hero-dot-pulse 1.55s ease-in-out infinite;
    }

    .hero-title {
        max-width: 820px;
        margin-top: 1.35rem;
        color: var(--color-heading);
        font-size: clamp(3.4rem, 7.8vw, 7.6rem);
        line-height: 0.9;
        letter-spacing: -0.06em;
    }

    .hero-title span {
        display: block;
        margin-top: 0.2rem;
        color: transparent;
        background: linear-gradient(
        135deg,
        var(--color-primary-dark),
        var(--color-secondary),
        var(--color-accent)
        );
        background-clip: text;
        -webkit-background-clip: text;
    }

    :global(.dark) .hero-title span {
        background: linear-gradient(
        135deg,
        var(--color-heading),
        var(--color-secondary),
        var(--color-accent)
        );
        background-clip: text;
        -webkit-background-clip: text;
    }

    .hero-description {
        max-width: 660px;
        margin-top: 1.35rem;
        color: var(--color-text-soft);
        font-size: clamp(1.05rem, 1.5vw, 1.25rem);
        line-height: 1.85;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-top: 2rem;
    }

    .hero-call {
        position: relative;
        overflow: hidden;
    }

    .btn-pulse {
        width: 0.65rem;
        height: 0.65rem;
        border-radius: 999px;
        background: currentColor;
        opacity: 0.9;
        box-shadow: 0 0 0 0 currentColor;
        animation: button-heartbeat 1.5s ease-in-out infinite;
    }

    .hero-trust {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        margin-top: 1.6rem;
    }

    .hero-visual {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 620px;
        width: 100%;
    }

    .hero-heart-stage {
        position: relative;
        display: grid;
        place-items: center;
        width: min(100%, 620px);
        min-height: 620px;
        margin-inline: auto;
    }

    .hero-heart-card {
        position: relative;
        display: grid;
        place-items: center;
        width: min(100%, 500px);
        aspect-ratio: 1;
        overflow: hidden;
        border: 1px solid color-mix(in srgb, var(--color-secondary) 32%, var(--color-border));
        border-radius: 42% 58% 52% 48% / 45% 43% 57% 55%;
        background:
        radial-gradient(
            circle at 50% 42%,
            color-mix(in srgb, var(--color-heart) 14%, transparent),
            transparent 11rem
        ),
        radial-gradient(
            circle at 52% 48%,
            color-mix(in srgb, var(--color-secondary) 24%, transparent),
            transparent 17rem
        ),
        linear-gradient(
            145deg,
            color-mix(in srgb, var(--color-surface) 86%, transparent),
            color-mix(in srgb, var(--color-surface-soft) 72%, transparent)
        );
        box-shadow:
        0 36px 90px rgba(15, 23, 42, 0.14),
        inset 0 1px 0 rgba(255, 255, 255, 0.32);
        backdrop-filter: blur(24px);
        animation:
        organic-heart-morph 9s ease-in-out infinite,
        heart-soft-beat 1.55s ease-in-out infinite;
    }

    :global(.dark) .hero-heart-card {
        box-shadow:
        0 36px 110px rgba(0, 0, 0, 0.36),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }

    .heart-grid {
        position: absolute;
        inset: 0;
        opacity: 0.52;
        background-image:
        linear-gradient(
            to right,
            color-mix(in srgb, var(--color-border) 72%, transparent) 1px,
            transparent 1px
        ),
        linear-gradient(
            to bottom,
            color-mix(in srgb, var(--color-border) 72%, transparent) 1px,
            transparent 1px
        );
        background-size: 34px 34px;
        mask-image: radial-gradient(circle at center, black, transparent 70%);
    }

    .heart-halo {
        position: absolute;
        width: min(90vw, 640px);
        aspect-ratio: 1;
        border-radius: 999px;
        background:
        radial-gradient(
            circle,
            color-mix(in srgb, var(--color-secondary) 20%, transparent),
            transparent 62%
        ),
        radial-gradient(
            circle,
            color-mix(in srgb, var(--color-accent) 12%, transparent),
            transparent 76%
        );
        filter: blur(8px);
        opacity: 0.8;
        animation: halo-breathe 4.6s ease-in-out infinite;
    }

    .hero-logo-shell {
        position: relative;
        z-index: 4;
        display: grid;
        place-items: center;
        width: clamp(7.5rem, 12vw, 10rem);
        aspect-ratio: 1;
        border: 1px solid color-mix(in srgb, var(--color-border) 75%, transparent);
        border-radius: 2rem;
        background:
        radial-gradient(
            circle at top,
            color-mix(in srgb, var(--color-secondary) 12%, transparent),
            transparent 6rem
        ),
        color-mix(in srgb, var(--color-surface) 78%, transparent);
        box-shadow: var(--shadow-card);
        backdrop-filter: blur(20px);
    }

    .hero-logo {
        grid-area: 1 / 1;
        width: 70%;
        height: 70%;
        object-fit: contain;
        transition:
        opacity 180ms ease,
        transform 220ms var(--motion-smooth);
    }

    .hero-logo-light {
        opacity: 1;
        transform: scale(1);
    }

    .hero-logo-dark {
        opacity: 0;
        transform: scale(0.96);
    }

    :global(.dark) .hero-logo-light {
        opacity: 0;
        transform: scale(0.96);
    }

    :global(.dark) .hero-logo-dark {
        opacity: 1;
        transform: scale(1);
    }

    .heartbeat-line {
        position: absolute;
        z-index: 3;
        left: 50%;
        top: 50%;
        width: 128%;
        transform: translate(-50%, -50%);
        filter: drop-shadow(
        0 0 12px color-mix(in srgb, var(--color-secondary) 48%, transparent)
        );
        pointer-events: none;
    }

    .heartbeat-shadow,
    .heartbeat-path {
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .heartbeat-shadow {
        stroke: color-mix(in srgb, var(--color-secondary) 18%, transparent);
        stroke-width: 12;
    }

    .heartbeat-path {
        stroke: var(--color-secondary);
        stroke-width: 5;
        stroke-dasharray: 930;
        stroke-dashoffset: 930;
        animation: draw-heartbeat 3.25s ease-in-out infinite;
    }

    .heart-beat-ring {
        position: absolute;
        inset: 9%;
        border: 1px solid color-mix(in srgb, var(--color-secondary) 35%, transparent);
        border-radius: inherit;
        opacity: 0;
        animation: heartbeat-ring 1.55s ease-out infinite;
    }

    .ring-two {
        animation-delay: 0.3s;
    }

    .hero-doctor-card {
        position: absolute;
        z-index: 6;
        right: 50%;
        bottom: 3.75rem;
        display: grid;
        gap: 0.5rem;
        width: min(78%, 315px);
        padding: 1.2rem;
        transform: translateX(50%);
    }

    .doctor-card-kicker {
        color: var(--color-secondary);
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .hero-doctor-card strong {
        color: var(--color-heading);
        font-family: var(--font-heading);
        font-size: clamp(1.45rem, 2vw, 2rem);
        line-height: 1;
        letter-spacing: -0.04em;
    }

    .doctor-card-line {
        width: 100%;
        height: 2px;
        margin-block: 0.25rem;
        border-radius: 999px;
        background: linear-gradient(
        90deg,
        var(--color-secondary),
        var(--color-heart),
        var(--color-accent)
        );
    }

    .doctor-card-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .doctor-card-meta span {
        border: 1px solid var(--color-border);
        border-radius: 999px;
        padding: 0.38rem 0.55rem;
        color: var(--color-text-soft);
        background: color-mix(in srgb, var(--color-surface) 68%, transparent);
        font-size: 0.78rem;
        font-weight: 800;
    }

    .hero-stat-card {
        position: absolute;
        z-index: 5;
        display: grid;
        gap: 0.25rem;
        width: 190px;
        padding: 1rem;
    }

    .hero-stat-card strong {
        color: var(--color-heading);
        font-family: var(--font-heading);
        font-size: 2.25rem;
        line-height: 1;
    }

    .hero-stat-card span {
        color: var(--color-text-soft);
        font-size: 0.82rem;
        font-weight: 800;
        line-height: 1.35;
    }

    .hero-stat-left {
        top: 4.25rem;
        left: 1.25rem;
        animation: float-soft 6.5s ease-in-out infinite;
    }

    .hero-stat-right {
        top: 3.25rem;
        right: 1.25rem;
        animation: float-soft 7.4s ease-in-out infinite reverse;
    }

    .hero-mini-card {
        position: absolute;
        z-index: 5;
        display: grid;
        gap: 0.15rem;
        border: 1px solid var(--color-border);
        border-radius: 1.2rem;
        padding: 0.85rem 1rem;
        background: color-mix(in srgb, var(--color-surface) 82%, transparent);
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(18px);
    }

    .hero-mini-card span {
        color: var(--color-text-soft);
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .hero-mini-card strong {
        color: var(--color-heading);
        font-size: 0.95rem;
        font-weight: 900;
    }

    .hero-location-card {
        left: 2rem;
        bottom: 6.25rem;
    }

    .hero-phone-card {
        right: 2rem;
        top: 13.5rem;
    }

    .hero-orb {
        position: absolute;
        z-index: 0;
        border-radius: 999px;
        filter: blur(60px);
        opacity: 0.52;
        pointer-events: none;
    }

    .hero-orb-one {
        top: 8%;
        left: 4%;
        width: 18rem;
        height: 18rem;
        background: color-mix(in srgb, var(--color-secondary) 35%, transparent);
    }

    .hero-orb-two {
        right: 8%;
        top: 16%;
        width: 24rem;
        height: 24rem;
        background: color-mix(in srgb, var(--color-accent) 28%, transparent);
    }

    .hero-orb-three {
        right: 28%;
        bottom: 10%;
        width: 18rem;
        height: 18rem;
        background: color-mix(in srgb, var(--color-heart) 16%, transparent);
    }

    @keyframes draw-heartbeat {
        0% {
        stroke-dashoffset: 930;
        opacity: 0;
        }

        12% {
        opacity: 1;
        }

        48% {
        stroke-dashoffset: 0;
        opacity: 1;
        }

        70% {
        stroke-dashoffset: 0;
        opacity: 0.9;
        }

        100% {
        stroke-dashoffset: -930;
        opacity: 0;
        }
    }

    @keyframes heart-soft-beat {
        0%,
        100% {
        transform: scale(1);
        }

        10% {
        transform: scale(1.018);
        }

        18% {
        transform: scale(1);
        }

        28% {
        transform: scale(1.012);
        }

        36% {
        transform: scale(1);
        }
    }

    @keyframes heartbeat-ring {
        0% {
        opacity: 0.4;
        transform: scale(0.9);
        }

        70% {
        opacity: 0;
        transform: scale(1.12);
        }

        100% {
        opacity: 0;
        transform: scale(1.12);
        }
    }

    @keyframes halo-breathe {
        0%,
        100% {
        opacity: 0.55;
        transform: scale(0.96);
        }

        50% {
        opacity: 0.9;
        transform: scale(1.04);
        }
    }

    @keyframes organic-heart-morph {
        0%,
        100% {
        border-radius: 42% 58% 52% 48% / 45% 43% 57% 55%;
        }

        35% {
        border-radius: 50% 50% 45% 55% / 47% 55% 45% 53%;
        }

        70% {
        border-radius: 46% 54% 58% 42% / 55% 45% 55% 45%;
        }
    }

    @keyframes hero-dot-pulse {
        0%,
        100% {
        box-shadow: 0 0 0 0
            color-mix(in srgb, var(--color-heart) 44%, transparent);
        transform: scale(1);
        }

        50% {
        box-shadow: 0 0 0 8px
            color-mix(in srgb, var(--color-heart) 0%, transparent);
        transform: scale(1.16);
        }
    }

    @keyframes button-heartbeat {
        0%,
        100% {
        transform: scale(1);
        opacity: 0.9;
        }

        18% {
        transform: scale(1.45);
        opacity: 0.65;
        }

        32% {
        transform: scale(1);
        opacity: 0.9;
        }
    }

    @media (max-width: 1080px) {
        .hero-container {
        grid-template-columns: 1fr;
        }

        .hero-copy {
        justify-items: center;
        text-align: center;
        }

        .hero-description {
        margin-inline: auto;
        }

        .hero-actions,
        .hero-trust {
        justify-content: center;
        }

        .hero-visual {
        min-height: 560px;
        }

        .hero-heart-stage {
        width: min(100%, 620px);
        min-height: 560px;
        }

        .hero-heart-card {
        width: min(100%, 470px);
        }
    }

    @media (max-width: 720px) {
        .home-hero {
        padding-top: 3.5rem;
        padding-bottom: 4rem;
        }

        .hero-container {
        gap: 2rem;
        }

        .hero-title {
        font-size: clamp(3.15rem, 15vw, 4.8rem);
        }

        .hero-actions {
        width: 100%;
        }

        .hero-trust .trust-badge {
        width: 100%;
        justify-content: center;
        }

        .hero-visual {
        min-height: 500px;
        width: 100%;
        overflow: hidden;
        }

        .hero-heart-stage {
        width: min(100%, 390px);
        min-height: 500px;
        }

        .hero-heart-card {
        width: min(100%, 340px);
        }

        .heartbeat-line {
        width: 145%;
        }

        .hero-stat-card {
        width: 140px;
        padding: 0.85rem;
        }

        .hero-stat-card strong {
        font-size: 1.65rem;
        }

        .hero-stat-left {
        top: 1.5rem;
        left: 0;
        }

        .hero-stat-right {
        top: auto;
        right: 0;
        bottom: 1rem;
        }

        .hero-doctor-card {
        right: 50%;
        bottom: 4rem;
        width: min(92%, 300px);
        transform: translateX(50%);
        }

        .hero-location-card {
        left: 0;
        bottom: 10.5rem;
        }

        .hero-phone-card {
        right: 0;
        top: 8.5rem;
        }
    }

    @media (max-width: 440px) {
        .hero-heart-stage {
        width: 100%;
        min-height: 455px;
        }

        .hero-heart-card {
        width: 300px;
        }

        .hero-logo-shell {
        width: 6rem;
        border-radius: 1.5rem;
        }

        .hero-mini-card {
        display: none;
        }

        .hero-stat-card {
        width: 128px;
        }

        .hero-doctor-card {
        bottom: 3rem;
        }
    }
</style>