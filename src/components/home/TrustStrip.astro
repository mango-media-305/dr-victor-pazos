---
import { HeartPulse } from "@lucide/astro";

import { contactInfo } from "../../data/site/contact";
import { ctaNavigation } from "../../data/site/navigation";
import { getLanguageFromUrl } from "../../data/i18n/language";
import type { LanguageCode } from "../../data/site/siteConfig";

interface Props {
    language?: LanguageCode;
}

const { language } = Astro.props as Props;

const currentLanguage = language ?? getLanguageFromUrl(Astro.url.pathname);

const content = {
    en: {
        kicker: "Patient confidence starts here",
        title: "Local heart care built around communication, access, and trust.",
        description:
            "From the first call to follow-up care, the practice is designed to help patients feel informed, respected, and supported in their heart-health decisions.",
        items: [
            {
                value: "35+",
                label: "Medical experience",
                description:
                    "Decades of practice helping patients navigate cardiovascular concerns with confidence.",
            },
            {
                value: "EN / ES",
                label: "Bilingual communication",
                description:
                    "Clear conversations in English and Spanish for patients and families.",
            },
            {
                value: "Hialeah",
                label: "Convenient access",
                description:
                    "A local office serving Hialeah, Miami Lakes, Doral, Miami, and nearby communities.",
            },
            {
                value: "MD",
                label: "Physician-led care",
                description:
                    "Evaluation and treatment planning guided by Victor Pazos, MD.",
            },
        ],
        callLabel: ctaNavigation.call.label.en,
        directionsLabel: contactInfo.map.directionsLabel.en,
    },
    es: {
        kicker: "Confianza desde el primer contacto",
        title: "Cuidado del corazón basado en comunicación, acceso y confianza.",
        description:
            "Desde la primera llamada hasta el seguimiento, la práctica está diseñada para que los pacientes se sientan informados, respetados y acompañados en sus decisiones de salud cardíaca.",
        items: [
            {
                value: "35+",
                label: "Experiencia médica",
                description:
                    "Décadas de práctica ayudando a pacientes a manejar sus preocupaciones cardiovasculares con confianza.",
            },
            {
                value: "EN / ES",
                label: "Comunicación bilingüe",
                description:
                    "Conversaciones claras en inglés y español para pacientes y familiares.",
            },
            {
                value: "Hialeah",
                label: "Acceso conveniente",
                description:
                    "Oficina local sirviendo a Hialeah, Miami Lakes, Doral, Miami y comunidades cercanas.",
            },
            {
                value: "MD",
                label: "Atención dirigida por médico",
                description:
                    "Evaluación y planificación de tratamiento guiada por Victor Pazos, MD.",
            },
        ],
        callLabel: ctaNavigation.call.label.es,
        directionsLabel: contactInfo.map.directionsLabel.es,
    },
};

const t = content[currentLanguage];
---

<section class="relative overflow-hidden section-padding-sm">
    <div class="site-container">
        <div
            class="trust-panel glow-panel relative grid gap-[clamp(1.5rem,3vw,2.25rem)] p-[clamp(1.25rem,3vw,2rem)] max-[680px]:rounded-[1.65rem]"
        >
            <div class="relative z-[1] grid gap-3">
                <span class="section-kicker">{t.kicker}</span>

                <div
                    class="grid grid-cols-1 gap-[clamp(1rem,4vw,3rem)] md:grid-cols-2 max-[1020px]:grid-cols-1"
                >
                    <h2
                        class="text-[clamp(2rem,5vw,4rem)] text-[var(--color-heading)]"
                    >
                        {t.title}
                    </h2>

                    <p
                        class="text-[clamp(1rem,1.35vw,1.12rem)] text-[var(--color-text-soft)]"
                    >
                        {t.description}
                    </p>
                </div>
            </div>

            <div
                class="relative z-[1] grid grid-cols-4 gap-[0.85rem] max-[1020px]:grid-cols-2 max-[680px]:grid-cols-1"
            >
                {
                    t.items.map((item, index) => (
                        <article
                            class="trust-card medical-card grid min-h-52 content-start gap-3 p-[1.15rem] max-[680px]:min-h-0"
                            style={`--trust-delay: ${index * 90}ms;`}
                        >
                            <div class="flex items-center justify-between gap-[0.85rem]">
                                <span
                                    class="font-heading text-[clamp(1rem,2vw,2rem)] font-extrabold text-[var(--color-heading)]"
                                >
                                    {item.value}
                                </span>

                                <span
                                    class="inline-grid size-11 flex-none place-items-center rounded-2xl border border-[color-mix(in_srgb,var(--color-heart)_24%,var(--color-border))] bg-[color-mix(in_srgb,var(--color-heart-soft)_52%,transparent)] text-[var(--color-heart)]"
                                    aria-hidden="true"
                                >
                                    <HeartPulse size={20} strokeWidth={2} />
                                </span>
                            </div>

                            <h3
                                class="font-body text-base font-black uppercase text-[var(--color-heading)]"
                            >
                                {item.label}
                            </h3>

                            <p class="text-[0.92rem]  text-[var(--color-text-soft)]">
                                {item.description}
                            </p>
                        </article>
                    ))
                }
            </div>

            <div
                class="relative z-[1] grid grid-cols-[1fr_auto] items-center gap-4 border-t border-[var(--color-border)] pt-[clamp(1rem,2vw,1.35rem)] max-[1020px]:grid-cols-1"
            >
                <div
                    class="grid grid-cols-[minmax(2rem,1fr)_minmax(140px,280px)_minmax(2rem,1fr)] items-center gap-[0.85rem] text-[var(--color-accent)] max-[680px]:grid-cols-[1fr_minmax(120px,220px)_1fr]"
                    aria-hidden="true"
                >
                    <span class="h-px bg-gradient-to-r from-transparent to-[color-mix(in_srgb,var(--color-border)_90%,transparent)]"></span>

                    <svg
                        viewBox="0 0 420 80"
                        fill="none"
                        class="h-auto w-full drop-shadow-[0_0_10px_color-mix(in_srgb,var(--color-accent)_42%,transparent)]"
                    >
                        <path
                            class="trust-heartline-path"
                            d="M0 42H86L104 42L122 42L139 15L165 68L188 42H222L240 42L258 28L278 56L298 42H420"
                        />
                    </svg>

                    <span class="h-px bg-gradient-to-r from-[color-mix(in_srgb,var(--color-border)_90%,transparent)] to-transparent"></span>
                </div>

                <div
                    class="flex justify-end gap-3 max-[1020px]:justify-start max-[680px]:grid max-[680px]:grid-cols-2"
                >
                    <a href={contactInfo.phone.href} class="btn btn-primary">
                        {t.callLabel}
                    </a>

                    <a
                        href={contactInfo.map.googleMapsUrl}
                        class="btn btn-secondary"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {t.directionsLabel}
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .trust-panel::after {
        content: "";
        position: absolute;
        inset: auto 8% -8rem auto;
        width: 18rem;
        aspect-ratio: 1;
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-heart) 12%, transparent);
        filter: blur(52px);
        pointer-events: none;
    }

    .trust-card {
        animation: trust-card-in 650ms var(--motion-smooth) both;
        animation-delay: var(--trust-delay);
    }

    .trust-heartline-path {
        stroke: currentColor;
        stroke-width: 4;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-dasharray: 540;
        stroke-dashoffset: 540;
        animation: trust-heartline-draw 2.7s ease-in-out infinite;
    }

    @keyframes trust-card-in {
        from {
            opacity: 0;
            transform: translateY(1rem);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes trust-heartline-draw {
        0% {
            opacity: 0;
            stroke-dashoffset: 540;
        }

        14% {
            opacity: 1;
        }

        54% {
            opacity: 1;
            stroke-dashoffset: 0;
        }

        76% {
            opacity: 0.85;
            stroke-dashoffset: 0;
        }

        100% {
            opacity: 0;
            stroke-dashoffset: -540;
        }
    }
</style>