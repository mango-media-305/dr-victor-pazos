---
import { ArrowRight, CircleAlert } from "@lucide/astro";

import { getLanguageFromUrl } from "../../data/i18n/language";
import type { LanguageCode } from "../../data/site/siteConfig";
import {
    cardiologyServices,
    getCardiologyServiceHref,
} from "../../data/services/cardiologyServices";

interface Props {
    language?: LanguageCode;
}

const { language } = Astro.props as Props;

const currentLanguage = language ?? getLanguageFromUrl(Astro.url.pathname);

const content = {
    en: {
        kicker: "How we can help",
        title: "Care for common heart symptoms, risk factors, and ongoing conditions.",
        description:
            "Patients often visit a cardiologist for chest discomfort, high blood pressure, palpitations, shortness of breath, abnormal test results, or long-term heart disease management.",
        viewAll: "View all cardiology services",
        viewService: "Explore service",
        href: "/services/",
        note: "If you are experiencing a medical emergency, call 911 or go to the nearest emergency room.",
    },
    es: {
        kicker: "Cómo podemos ayudarle",
        title: "Atención para síntomas cardíacos, factores de riesgo y condiciones continuas.",
        description:
            "Los pacientes suelen visitar a un cardiólogo por dolor en el pecho, presión alta, palpitaciones, falta de aire, resultados anormales o manejo continuo de enfermedades del corazón.",
        viewAll: "Ver todos los servicios de cardiología",
        viewService: "Explorar servicio",
        href: "/es/servicios/",
        note: "Si está experimentando una emergencia médica, llame al 911 o vaya a la sala de emergencias más cercana.",
    },
};

const t = content[currentLanguage];

const services = cardiologyServices.map((service) => ({
    ...service,
    Icon: service.icon,
}));
---

<section class="relative isolate overflow-hidden section-padding">
    <div
        class="pointer-events-none absolute right-[-4rem] top-[10%] z-[-1] aspect-square w-80 rounded-full bg-[color-mix(in_srgb,var(--color-secondary)_24%,transparent)] opacity-45 blur-[58px]"
    >
    </div>

    <div
        class="pointer-events-none absolute bottom-[6%] left-[-5rem] z-[-1] aspect-square w-72 rounded-full bg-[color-mix(in_srgb,var(--color-accent)_20%,transparent)] opacity-45 blur-[58px]"
    >
    </div>

    <div class="site-container">
        <div
            class="relative z-[1] mb-[clamp(1.75rem,4vw,3rem)] grid gap-[0.85rem]"
        >
            <span class="section-kicker">{t.kicker}</span>

            <div class="grid grid-cols-1 gap-8">
                <h2
                    class="text-[clamp(2.3rem,5.5vw,5.15rem)] leading-[0.98] tracking-[-0.06em] text-[var(--color-heading)]"
                >
                    {t.title}
                </h2>

                <div class="grid justify-items-start gap-5 max-[680px]:justify-items-stretch">
                    <p
                        class="text-[clamp(1rem,1.35vw,1.15rem)] leading-[1.85] text-[var(--color-text-soft)]"
                    >
                        {t.description}
                    </p>

                    <a
                        href={t.href}
                        class="btn btn-secondary w-fit max-[680px]:w-full"
                    >
                        {t.viewAll}
                    </a>
                </div>
            </div>
        </div>

        <div
            class="relative z-[1] grid grid-cols-3 gap-[0.95rem] max-[1060px]:grid-cols-2 max-[680px]:grid-cols-1"
        >
            {
                services.map((service, index) => {
                    const Icon = service.Icon;

                    return (
                        <a
                            href={getCardiologyServiceHref(service, currentLanguage)}
                            class="service-card-link medical-card group grid min-h-72 content-between p-[clamp(1.1rem,2vw,1.35rem)] text-inherit max-[680px]:min-h-0"
                            style={`--service-delay: ${index * 80}ms;`}
                            aria-label={`${t.viewService}: ${service.title[currentLanguage]}`}
                        >
                            <div class="relative z-[1] flex items-center justify-between gap-4">
                                <span
                                    class="inline-grid size-[3.2rem] place-items-center rounded-[1.05rem] border border-[color-mix(in_srgb,var(--color-secondary)_32%,var(--color-border))] bg-[color-mix(in_srgb,var(--color-surface)_76%,transparent)] text-[var(--color-secondary)] shadow-[0_14px_34px_rgba(15,23,42,0.07)]"
                                    aria-hidden="true"
                                >
                                    <Icon class="h-7 w-7" />
                                </span>

                                <span
                                    class="font-heading text-[2.4rem] font-extrabold leading-none tracking-[-0.06em] text-[color-mix(in_srgb,var(--color-accent)_76%,var(--color-text-muted))] opacity-55"
                                >
                                    {String(index + 1).padStart(2, "0")}
                                </span>
                            </div>

                            <div class="relative z-[1] mt-[2.4rem] grid gap-3 max-[680px]:mt-7">
                                <h3
                                    class="font-heading text-[clamp(1.55rem,2.4vw,2.25rem)] leading-[1.02] tracking-[-0.045em] text-[var(--color-heading)]"
                                >
                                    {service.shortTitle[currentLanguage]}
                                </h3>

                                <p class="text-[0.96rem] leading-[1.7] text-[var(--color-text-soft)]">
                                    {service.shortDescription[currentLanguage]}
                                </p>
                            </div>

                            <span
                                class="relative z-[1] mt-[1.35rem] inline-flex w-fit items-center gap-[0.45rem] text-[0.88rem] font-black tracking-[-0.01em] text-[var(--color-secondary)] transition-[color,transform] duration-200 group-hover:translate-x-1 group-hover:text-[var(--color-accent-dark)] dark:group-hover:text-[var(--color-accent)]"
                            >
                                {t.viewService}

                                <ArrowRight size={18} strokeWidth={2} aria-hidden="true" />
                            </span>
                        </a>
                    );
                })
            }
        </div>

        <div
            class="relative z-[1] mt-[clamp(1.25rem,3vw,2rem)] flex w-fit max-w-[760px] items-start gap-[0.65rem] rounded-[1.25rem] border border-[color-mix(in_srgb,var(--color-accent)_30%,var(--color-border))] bg-[color-mix(in_srgb,var(--color-accent-soft)_44%,transparent)] px-4 py-[0.85rem] text-[var(--color-accent-dark)] dark:bg-[color-mix(in_srgb,var(--color-accent-soft)_34%,transparent)] dark:text-[var(--color-accent)] max-[680px]:w-full"
        >
            <span class="mt-[0.12rem] flex-none" aria-hidden="true">
                <CircleAlert size={18} strokeWidth={2} />
            </span>

            <p class="text-sm leading-[1.55] text-current">{t.note}</p>
        </div>
    </div>
</section>

<style>
    .service-card-link {
        position: relative;
        overflow: hidden;
        animation: service-card-in 650ms var(--motion-smooth) both;
        animation-delay: var(--service-delay);
    }

    .service-card-link::before {
        content: "";
        position: absolute;
        inset: 0;
        opacity: 0;
        background:
            radial-gradient(
                circle at top right,
                color-mix(in srgb, var(--color-secondary) 22%, transparent),
                transparent 13rem
            ),
            radial-gradient(
                circle at bottom left,
                color-mix(in srgb, var(--color-accent) 14%, transparent),
                transparent 12rem
            );
        transition: opacity 240ms var(--motion-smooth);
        pointer-events: none;
    }

    .service-card-link:hover::before {
        opacity: 1;
    }

    .service-card-link span[aria-hidden="true"] {
        background:
            radial-gradient(
                circle at top,
                color-mix(in srgb, var(--color-secondary) 18%, transparent),
                transparent 4rem
            ),
            color-mix(in srgb, var(--color-surface) 76%, transparent);
    }

    @keyframes service-card-in {
        from {
            opacity: 0;
            transform: translateY(1.15rem) scale(0.985);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
</style>