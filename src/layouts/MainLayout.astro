---
import "../styles/global.css";

import Header from "../components/global/Header.astro";
import Footer from "../components/global/Footer.astro";

import { ClientRouter } from "astro:transitions";

import { siteConfig, type LanguageCode } from "../data/site/siteConfig";
import {
    defaultLanguage,
    getLanguageFromUrl,
    languages,
} from "../data/i18n/language";

type SchemaObject = Record<string, unknown>;

interface Props {
    title?: string;
    description?: string;
    image?: string;
    canonical?: string;
    noindex?: boolean;
    language?: LanguageCode;
    bodyClass?: string;
    schema?: SchemaObject | SchemaObject[];
    alternateUrls?: Partial<Record<LanguageCode, string>>;
}

const {
    title,
    description,
    image = siteConfig.seo.defaultImage,
    canonical,
    noindex = false,
    language,
    bodyClass = "",
    schema = [],
    alternateUrls = {},
}: Props = Astro.props;

const resolvedLanguage = language ?? getLanguageFromUrl(Astro.url.pathname);
const currentLanguage: LanguageCode =
    resolvedLanguage in languages
        ? (resolvedLanguage as LanguageCode)
        : defaultLanguage;

const currentLocale = languages[currentLanguage].locale;
const currentDirection = languages[currentLanguage].direction;

const defaultTitle = siteConfig.seo.defaultTitle[currentLanguage];
const defaultDescription = siteConfig.seo.defaultDescription[currentLanguage];

const pageTitle = title
    ? siteConfig.seo.titleTemplate[currentLanguage].replace("%s", title)
    : defaultTitle;

const pageDescription = description ?? defaultDescription;

const siteUrl = siteConfig.domain.replace(/\/$/, "");

function toAbsoluteUrl(pathOrUrl: string): string {
    if (pathOrUrl.startsWith("http://") || pathOrUrl.startsWith("https://")) {
        return pathOrUrl;
    }

    const normalizedPath = pathOrUrl.startsWith("/")
        ? pathOrUrl
        : `/${pathOrUrl}`;

    return `${siteUrl}${normalizedPath}`;
}

const canonicalUrl = canonical
    ? toAbsoluteUrl(canonical)
    : toAbsoluteUrl(Astro.url.pathname);

const imageUrl = toAbsoluteUrl(image);

const schemaArray = Array.isArray(schema) ? schema : [schema];

const filteredSchema = schemaArray.filter(Boolean);

const hasSchema = filteredSchema.length > 0;

const alternateEntries = Object.entries(alternateUrls).filter(([, href]) =>
    Boolean(href),
) as [LanguageCode, string][];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={currentLanguage} dir={currentDirection} data-theme="light">
    <head>
        <meta charset="UTF-8" />

        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <meta name="generator" content={Astro.generator} />

        <!-- Prevent dark/light theme flash before hydration -->
        <script is:inline>
        (() => {
            try {
            const storageKey = "victor-pazos-theme";
            const storedTheme = localStorage.getItem(storageKey);
            const prefersDark = window.matchMedia(
                "(prefers-color-scheme: dark)",
            ).matches;

            const theme =
                storedTheme === "light" || storedTheme === "dark"
                ? storedTheme
                : prefersDark
                    ? "dark"
                    : "light";

            document.documentElement.classList.toggle("dark", theme === "dark");
            document.documentElement.dataset.theme = theme;
            } catch {
            document.documentElement.dataset.theme = "light";
            }
        })();
        </script>

        <ClientRouter />

        <title>{pageTitle}</title>
        <meta name="description" content={pageDescription} />

        {noindex && <meta name="robots" content="noindex, nofollow" />}

        <link rel="canonical" href={canonicalUrl} />

        {
        alternateEntries.map(([lang, href]) => (
            <link
            rel="alternate"
            hreflang={languages[lang].locale}
            href={toAbsoluteUrl(href)}
            />
        ))
        }

        {
        alternateEntries.length > 0 && (
            <link
            rel="alternate"
            hreflang="x-default"
            href={
                alternateUrls[defaultLanguage]
                ? toAbsoluteUrl(alternateUrls[defaultLanguage]!)
                : canonicalUrl
            }
            />
        )
        }

        <!-- Favicons -->
        <link rel="icon" href={siteConfig.assets.favicon} />
        <link rel="apple-touch-icon" href={siteConfig.assets.appleTouchIcon} />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:site_name" content={siteConfig.name} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={imageUrl} />
        <meta property="og:locale" content={currentLocale} />

        {
        currentLanguage === "en" && (
            <meta property="og:locale:alternate" content="es_US" />
        )
        }

        {
        currentLanguage === "es" && (
            <meta property="og:locale:alternate" content="en_US" />
        )
        }

        <!-- Twitter / X -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={pageDescription} />
        <meta name="twitter:image" content={imageUrl} />

        <!-- Search engine verification placeholders -->
        {
        siteConfig.analytics.googleSearchConsoleVerification && (
            <meta
            name="google-site-verification"
            content={siteConfig.analytics.googleSearchConsoleVerification}
            />
        )
        }

        {
        siteConfig.analytics.bingWebmasterVerification && (
            <meta
            name="msvalidate.01"
            content={siteConfig.analytics.bingWebmasterVerification}
            />
        )
        }

        {
        hasSchema && (
            <script
            type="application/ld+json"
            set:html={JSON.stringify(
                filteredSchema.length === 1 ? filteredSchema[0] : filteredSchema,
            )}
            />
        )
        }

        <!-- Microsoft Clarity placeholder -->
        {
        siteConfig.analytics.microsoftClarityId && (
            <script
            is:inline
            set:html={`
                (function(c,l,a,r,i,t,y){
                c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
                t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
                y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
                })(window, document, "clarity", "script", "${siteConfig.analytics.microsoftClarityId}");
            `}
            />
        )
        }

        <!-- Google Analytics placeholder -->
        {
        siteConfig.analytics.googleAnalyticsId && (
            <>
            <script
                async
                src={`https://www.googletagmanager.com/gtag/js?id=${siteConfig.analytics.googleAnalyticsId}`}
            />
            <script
                is:inline
                set:html={`
                window.dataLayer = window.dataLayer || [];
                function gtag(){dataLayer.push(arguments);}
                gtag("js", new Date());
                gtag("config", "${siteConfig.analytics.googleAnalyticsId}");
                `}
            />
            </>
        )
        }
    </head>

    <body class={`site-bg ${bodyClass}`}>
        <a class="skip-link" href="#main-content">
            {currentLanguage === "es" ? "Saltar al contenido" : "Skip to content"}
        </a>

        <Header language={currentLanguage} />

        <main id="main-content">
            <slot />
        </main>

        <Footer language={currentLanguage} />

        <script>
            import "../scripts/theme";
        </script>
    </body>
</html>

<style is:global>
    .skip-link {
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 9999;
        transform: translateY(-150%);
        border-radius: 999px;
        padding: 0.8rem 1rem;
        color: #ffffff;
        background: var(--color-primary);
        font-weight: 800;
        box-shadow: var(--shadow-card);
        transition: transform 180ms ease;
    }

    .skip-link:focus {
        transform: translateY(0);
    }
</style>
